    {
      "id": "space-flatiron-gtm-file-0",
      "name": "index.html",
      "type": "code",
      "mimeType": "text/html",
      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&family=Google+Sans+Text:wght@400;500&display=swap\" rel=\"stylesheet\">\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <style>\n    :root {\n      --gemini-rail-icon-gap: 0px;\n      --gemini-side-panel-padding-left: 16px;\n      --gemini-side-panel-padding-right: 16px;\n      --gemini-header-padding-left: 10px;\n      --gemini-header-padding-right: 12px;\n      --gemini-header-elements-gap: 8px;\n    }\n    body {\n      font-family: 'Google Sans Text', sans-serif;\n      background-color: #ffffff;\n      color: #1f1f1f;\n    }\n    h1, h2, h3, h4, h5, button {\n      font-family: 'Google Sans', sans-serif;\n    }\n    /* Minimal custom scrollbar */\n    ::-webkit-scrollbar {\n      width: 6px;\n      height: 6px;\n    }\n    ::-webkit-scrollbar-track {\n      background: transparent;\n    }\n    ::-webkit-scrollbar-thumb {\n      background: #e2e8f0;\n      border-radius: 3px;\n    }\n    ::-webkit-scrollbar-thumb:hover {\n      background: #cbd5e1;\n    }\n  </style>\n  <title>Decision & Risk Log</title>\n</head>\n<body class=\"p-6 bg-white text-[#1f1f1f]\">\n  <div class=\"max-w-6xl mx-auto space-y-6\">\n    \n    <!-- Controls Interface -->\n    <div class=\"flex flex-col md:flex-row md:items-center justify-between gap-4 pb-4 border-b border-[#e2e8f0]\">\n      <!-- Tab Controls -->\n      <div class=\"flex space-x-1 p-1 bg-[#f0f4f9] rounded-lg w-fit\">\n        <button id=\"tab-decisions\" onclick=\"switchTab('decisions')\" class=\"px-4 py-1.5 text-xs font-medium rounded-md transition duration-150 ease-in-out bg-white text-[#1f1f1f] shadow-sm\">\n          Decisions Log\n        </button>\n        <button id=\"tab-risks\" onclick=\"switchTab('risks')\" class=\"px-4 py-1.5 text-xs font-medium rounded-md transition duration-150 ease-in-out text-[#5f6368] hover:text-[#1f1f1f]\">\n          Risks & Mitigations\n        </button>\n      </div>\n\n      <!-- Search & Add Actions -->\n      <div class=\"flex items-center space-x-3\">\n        <div class=\"relative\">\n          <input type=\"text\" id=\"search-input\" oninput=\"handleSearch()\" placeholder=\"Search logs...\" class=\"w-48 md:w-64 pl-8 pr-3 py-1.5 text-xs bg-[#f0f4f9] hover:bg-[#e8f0fe] focus:bg-white border border-transparent focus:border-[#0b57d0] rounded-lg outline-none transition\">\n          <svg class=\"absolute left-2.5 top-2.5 w-3.5 h-3.5 text-[#5f6368]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\"></path>\n          </svg>\n        </div>\n        <button id=\"add-btn\" onclick=\"openAddModal()\" class=\"px-4 py-1.5 bg-[#0b57d0] hover:bg-[#0842a0] text-white text-xs font-medium rounded-lg transition duration-150 flex items-center space-x-1\">\n          <span class=\"text-sm\">+</span> <span>New Decision</span>\n        </button>\n      </div>\n    </div>\n\n    <!-- Decisions Container -->\n    <div id=\"decisions-container\" class=\"overflow-x-auto\">\n      <table class=\"w-full text-left text-xs border-collapse\">\n        <thead>\n          <tr class=\"text-[#5f6368] border-b border-[#e2e8f0]\">\n            <th class=\"pb-3 font-medium text-[11px] uppercase tracking-wider w-1/2\">Decision Details</th>\n            <th class=\"pb-3 font-medium text-[11px] uppercase tracking-wider\">Date</th>\n            <th class=\"pb-3 font-medium text-[11px] uppercase tracking-wider\">Owner</th>\n            <th class=\"pb-3 font-medium text-[11px] uppercase tracking-wider\">Status</th>\n            <th class=\"pb-3 font-medium text-[11px] uppercase tracking-wider text-right\">Actions</th>\n          </tr>\n        </thead>\n        <tbody class=\"divide-y divide-[#e2e8f0] text-[#1f1f1f]\" id=\"decisions-tbody\">\n          <!-- Dynamically populated -->\n        </tbody>\n      </table>\n    </div>\n\n    <!-- Risks & Mitigations Container -->\n    <div id=\"risks-container\" class=\"overflow-x-auto hidden\">\n      <table class=\"w-full text-left text-xs border-collapse\">\n        <thead>\n          <tr class=\"text-[#5f6368] border-b border-[#e2e8f0]\">\n            <th class=\"pb-3 font-medium text-[11px] uppercase tracking-wider w-1/3\">Identified Risk & Impact</th>\n            <th class=\"pb-3 font-medium text-[11px] uppercase tracking-wider w-1/3\">Mitigation Plan</th>\n            <th class=\"pb-3 font-medium text-[11px] uppercase tracking-wider\">Severity</th>\n            <th class=\"pb-3 font-medium text-[11px] uppercase tracking-wider\">Owner</th>\n            <th class=\"pb-3 font-medium text-[11px] uppercase tracking-wider\">Status</th>\n            <th class=\"pb-3 font-medium text-[11px] uppercase tracking-wider text-right\">Actions</th>\n          </tr>\n        </thead>\n        <tbody class=\"divide-y divide-[#e2e8f0] text-[#1f1f1f]\" id=\"risks-tbody\">\n          <!-- Dynamically populated -->\n        </tbody>\n      </table>\n    </div>\n  </div>\n\n  <!-- Form Overlay Modal -->\n  <div id=\"modal-backdrop\" class=\"fixed inset-0 bg-black/20 backdrop-blur-[1px] hidden items-center justify-center z-50 transition duration-150\">\n    <div class=\"bg-white rounded-xl border border-[#e2e8f0] w-full max-w-lg p-6 space-y-4 shadow-sm\">\n      <div class=\"flex items-center justify-between border-b border-[#e2e8f0] pb-3\">\n        <h3 id=\"modal-title\" class=\"text-sm font-medium text-[#1f1f1f]\">Add Log Entry</h3>\n        <button onclick=\"closeModal()\" class=\"text-[#5f6368] hover:text-[#1f1f1f] p-1 rounded-md hover:bg-[#f0f4f9] transition\">\n          <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M6 18L18 6M6 6l12 12\"></path>\n          </svg>\n        </button>\n      </div>\n\n      <form id=\"record-form\" onsubmit=\"handleFormSubmit(event)\" class=\"space-y-4\">\n        <input type=\"hidden\" id=\"form-id\">\n        <input type=\"hidden\" id=\"form-type\">\n\n        <!-- Title -->\n        <div class=\"space-y-1\">\n          <label id=\"lbl-title\" class=\"block text-xs font-medium text-[#5f6368]\">Title</label>\n          <input type=\"text\" id=\"form-title\" required class=\"w-full px-3 py-2 text-xs border border-slate-200 rounded-lg focus:border-[#0b57d0] focus:outline-none bg-white text-[#1f1f1f]\">\n        </div>\n\n        <!-- Owner -->\n        <div class=\"space-y-1\">\n          <label class=\"block text-xs font-medium text-[#5f6368]\">Owner</label>\n          <select id=\"form-owner\" required class=\"w-full px-3 py-2 text-xs border border-slate-200 rounded-lg focus:border-[#0b57d0] focus:outline-none bg-white text-[#1f1f1f]\">\n            <!-- Filled dynamically -->\n          </select>\n        </div>\n\n        <!-- Decisions Fields (Date & Notes) -->\n        <div id=\"decision-only-fields\" class=\"space-y-4\">\n          <div class=\"space-y-1\">\n            <label class=\"block text-xs font-medium text-[#5f6368]\">Date</label>\n            <input type=\"date\" id=\"form-date\" class=\"w-full px-3 py-2 text-xs border border-slate-200 rounded-lg focus:border-[#0b57d0] focus:outline-none bg-white text-[#1f1f1f]\">\n          </div>\n          <div class=\"space-y-1\">\n            <label class=\"block text-xs font-medium text-[#5f6368]\">Background & Notes</label>\n            <textarea id=\"form-notes\" rows=\"3\" class=\"w-full px-3 py-2 text-xs border border-slate-200 rounded-lg focus:border-[#0b57d0] focus:outline-none bg-white text-[#1f1f1f]\"></textarea>\n          </div>\n        </div>\n\n        <!-- Risks Fields (Mitigation & Severity) -->\n        <div id=\"risk-only-fields\" class=\"space-y-4 hidden\">\n          <div class=\"space-y-1\">\n            <label class=\"block text-xs font-medium text-[#5f6368]\">Severity</label>\n            <select id=\"form-severity\" class=\"w-full px-3 py-2 text-xs border border-slate-200 rounded-lg focus:border-[#0b57d0] focus:outline-none bg-white text-[#1f1f1f]\">\n              <option value=\"Low\">Low</option>\n              <option value=\"Medium\">Medium</option>\n              <option value=\"High\">High</option>\n            </select>\n          </div>\n          <div class=\"space-y-1\">\n            <label class=\"block text-xs font-medium text-[#5f6368]\">Mitigation Plan</label>\n            <textarea id=\"form-mitigation\" rows=\"3\" class=\"w-full px-3 py-2 text-xs border border-slate-200 rounded-lg focus:border-[#0b57d0] focus:outline-none bg-white text-[#1f1f1f]\"></textarea>\n          </div>\n        </div>\n\n        <!-- Status -->\n        <div class=\"space-y-1\">\n          <label class=\"block text-xs font-medium text-[#5f6368]\">Status</label>\n          <select id=\"form-status\" required class=\"w-full px-3 py-2 text-xs border border-slate-200 rounded-lg focus:border-[#0b57d0] focus:outline-none bg-white text-[#1f1f1f]\">\n            <!-- Filled dynamically -->\n          </select>\n        </div>\n\n        <!-- Actions -->\n        <div class=\"flex items-center justify-end space-x-2 pt-3 border-t border-[#e2e8f0]\">\n          <button type=\"button\" onclick=\"closeModal()\" class=\"px-4 py-2 bg-[#f0f4f9] hover:bg-[#e2e8f0] text-[#1f1f1f] text-xs font-medium rounded-lg transition\">Cancel</button>\n          <button type=\"submit\" class=\"px-4 py-2 bg-[#0b57d0] hover:bg-[#0842a0] text-white text-xs font-medium rounded-lg transition\">Save Entry</button>\n        </div>\n      </form>\n    </div>\n  </div>\n\n  <!-- Real-Time Sync & UI Engine -->\n  <script>\n    const envId = window.__sandboxEnvId;\n    const syncKey = \"oncotrials_alignment_tracker_v1\";\n\n    let activeTab = 'decisions';\n    let isModalOpen = false;\n\n    // Real Workspace Team Members\n    const teamMembers = [\n      { name: \"Sakura Okoro\", email: \"sakura@example.com\", color: { bg: \"#e8f0fe\", text: \"#1a73e8\" }, initials: \"SO\" },\n      { name: \"Malik Harold\", email: \"malik@example.com\", color: { bg: \"#fce8e6\", text: \"#d93025\" }, initials: \"MH\" },\n      { name: \"Adam Lee\", email: \"adam@example.com\", color: { bg: \"#e6f4ea\", text: \"#137333\" }, initials: \"AL\" }\n    ];\n\n    // Initial Realistic Dataset (Strictly related to the OncoTrials Workspace context)\n    const defaultState = {\n      decisions: [\n        {\n          id: \"dec-1\",\n          title: \"Approve OncoEMR Integration protocol for Rocky Mountain Cancer Centers\",\n          owner: \"Sakura Okoro\",\n          date: \"2026-07-10\",\n          status: \"Approved\",\n          notes: \"Security audit cleared and API gateway approved for pilot EMR data connection.\"\n        },\n        {\n          id: \"dec-2\",\n          title: \"Standardize CRC Workflow Training to a 2-day virtual curriculum\",\n          owner: \"Adam Lee\",\n          date: \"2026-07-14\",\n          status: \"Proposed\",\n          notes: \"Proposed shift to 100% remote self-paced training with interactive Q&A clinics.\"\n        },\n        {\n          id: \"dec-3\",\n          title: \"Approve Biomarker Gateway Setup schema for Highlands Oncology Group\",\n          owner: \"Malik Harold\",\n          date: \"2026-07-12\",\n          status: \"Approved\",\n          notes: \"Validated HL7 FHIR profile matches core clinical trials platform requirements.\"\n        }\n      ],\n      risks: [\n        {\n          id: \"risk-1\",\n          title: \"Delays in EMR connection validation by community clinical sites\",\n          owner: \"Malik Harold\",\n          severity: \"High\",\n          mitigation: \"Provide automated self-service validation scripts to ease external IT burdens.\",\n          status: \"Active\"\n        },\n        {\n          id: \"risk-2\",\n          title: \"Low clinical coordinator engagement during training modules\",\n          owner: \"Sakura Okoro\",\n          severity: \"Medium\",\n          mitigation: \"Conduct weekly drop-in clinic hours and issue digital enablement badges on completion.\",\n          status: \"Mitigated\"\n        },\n        {\n          id: \"risk-3\",\n          title: \"Data latency in the point-of-care matching gateway alerts\",\n          owner: \"Adam Lee\",\n          severity: \"High\",\n          mitigation: \"Optimize database query rules and implement local 24-hour cache refreshing.\",\n          status: \"Active\"\n        }\n      ]\n    };\n\n    let state = { ...defaultState };\n\n    // Get assignee data safely\n    function getMemberByName(name) {\n      return teamMembers.find(m => m.name === name) || teamMembers[0];\n    }\n\n    // Render cleanly-designed custom inline initials badge\n    function renderAssigneeBadge(name) {\n      const member = getMemberByName(name);\n      return `\n        <div class=\"flex items-center space-x-2\">\n          <div class=\"w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-bold select-none cursor-default\" style=\"background-color: ${member.color.bg}; color: ${member.color.text}\">\n            ${member.initials}\n          </div>\n          <span class=\"text-xs text-[#1f1f1f] font-medium whitespace-nowrap\">${member.name}</span>\n        </div>\n      `;\n    }\n\n    // Escape inputs to ensure high security\n    function escapeHTML(str) {\n      if (!str) return '';\n      return str.replace(/&/g, \"&amp;\").replace(/</g, \"&lt;\").replace(/>/g, \"&gt;\").replace(/\"/g, \"&quot;\").replace(/'/g, \"&#039;\");\n    }\n\n    // Render layout dynamically\n    function render() {\n      const query = document.getElementById('search-input').value.toLowerCase().trim();\n      \n      if (activeTab === 'decisions') {\n        document.getElementById('decisions-container').classList.remove('hidden');\n        document.getElementById('risks-container').classList.add('hidden');\n        document.getElementById('add-btn').innerHTML = '<span class=\"text-sm\">+</span> <span>New Decision</span>';\n        \n        const tbody = document.getElementById('decisions-tbody');\n        tbody.innerHTML = '';\n        \n        const filteredDecisions = state.decisions.filter(d => {\n          return d.title.toLowerCase().includes(query) ||\n                 (d.notes && d.notes.toLowerCase().includes(query)) ||\n                 d.owner.toLowerCase().includes(query) ||\n                 d.status.toLowerCase().includes(query) ||\n                 d.date.includes(query);\n        });\n\n        if (filteredDecisions.length === 0) {\n          tbody.innerHTML = `\n            <tr>\n              <td colspan=\"5\" class=\"py-8 text-center text-[#5f6368] text-xs\">No aligned decisions found matching your criteria.</td>\n            </tr>\n          `;\n        } else {\n          filteredDecisions.forEach(item => {\n            const row = document.createElement('tr');\n            row.className = \"hover:bg-[#f8f9fa] transition\";\n            row.innerHTML = `\n              <td class=\"py-3.5 pr-4 align-top\">\n                <div class=\"font-medium text-[#1f1f1f] text-sm\">${escapeHTML(item.title)}</div>\n                <div class=\"text-xs text-[#5f6368] mt-1\">${escapeHTML(item.notes || '')}</div>\n              </td>\n              <td class=\"py-3.5 pr-4 align-top whitespace-nowrap text-[#5f6368] text-xs\">${escapeHTML(item.date)}</td>\n              <td class=\"py-3.5 pr-4 align-top\">${renderAssigneeBadge(item.owner)}</td>\n              <td class=\"py-3.5 pr-4 align-top whitespace-nowrap\">\n                <select onchange=\"updateStatus('${item.id}', 'decisions', this.value)\" class=\"px-2 py-1 bg-[#f0f4f9] hover:bg-[#e2e8f0] text-[#1f1f1f] text-xs font-medium rounded-lg cursor-pointer focus:outline-none focus:ring-1 focus:ring-[#0b57d0]\">\n                  <option value=\"Proposed\" ${item.status === 'Proposed' ? 'selected' : ''}>Proposed</option>\n                  <option value=\"Approved\" ${item.status === 'Approved' ? 'selected' : ''}>Approved</option>\n                  <option value=\"Rejected\" ${item.status === 'Rejected' ? 'selected' : ''}>Rejected</option>\n                </select>\n              </td>\n              <td class=\"py-3.5 align-top text-right whitespace-nowrap\">\n                <div class=\"flex items-center justify-end space-x-1\">\n                  <button onclick=\"openEditModal('${item.id}', 'decisions')\" class=\"p-1.5 hover:bg-[#f0f4f9] rounded-md text-[#5f6368] hover:text-[#1f1f1f] transition\" title=\"Edit\">\n                    <svg class=\"w-3.5 h-3.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z\"></path></svg>\n                  </button>\n                  <button onclick=\"deleteEntry('${item.id}', 'decisions')\" class=\"p-1.5 hover:bg-[#fce8e6] rounded-md text-[#5f6368] hover:text-[#d93025] transition\" title=\"Delete\">\n                    <svg class=\"w-3.5 h-3.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16\"></path></svg>\n                  </button>\n                </div>\n              </td>\n            `;\n            tbody.appendChild(row);\n          });\n        }\n      } else {\n        document.getElementById('decisions-container').classList.add('hidden');\n        document.getElementById('risks-container').classList.remove('hidden');\n        document.getElementById('add-btn').innerHTML = '<span class=\"text-sm\">+</span> <span>New Risk</span>';\n        \n        const tbody = document.getElementById('risks-tbody');\n        tbody.innerHTML = '';\n        \n        const filteredRisks = state.risks.filter(r => {\n          return r.title.toLowerCase().includes(query) ||\n                 (r.mitigation && r.mitigation.toLowerCase().includes(query)) ||\n                 r.owner.toLowerCase().includes(query) ||\n                 r.status.toLowerCase().includes(query) ||\n                 r.severity.toLowerCase().includes(query);\n        });\n\n        if (filteredRisks.length === 0) {\n          tbody.innerHTML = `\n            <tr>\n              <td colspan=\"6\" class=\"py-8 text-center text-[#5f6368] text-xs\">No tracked risks found matching your criteria.</td>\n            </tr>\n          `;\n        } else {\n          filteredRisks.forEach(item => {\n            let severityColorClass = \"text-[#5f6368]\";\n            if (item.severity === 'High') {\n              severityColorClass = \"text-[#d93025] font-medium\";\n            } else if (item.severity === 'Medium') {\n              severityColorClass = \"text-[#b06000] font-medium\";\n            }\n\n            const row = document.createElement('tr');\n            row.className = \"hover:bg-[#f8f9fa] transition\";\n            row.innerHTML = `\n              <td class=\"py-3.5 pr-4 align-top\">\n                <div class=\"font-medium text-[#1f1f1f] text-sm\">${escapeHTML(item.title)}</div>\n              </td>\n              <td class=\"py-3.5 pr-4 align-top\">\n                <div class=\"text-xs text-[#5f6368]\">${escapeHTML(item.mitigation || '')}</div>\n              </td>\n              <td class=\"py-3.5 pr-4 align-top whitespace-nowrap text-xs ${severityColorClass}\">${escapeHTML(item.severity)}</td>\n              <td class=\"py-3.5 pr-4 align-top\">${renderAssigneeBadge(item.owner)}</td>\n              <td class=\"py-3.5 pr-4 align-top whitespace-nowrap\">\n                <select onchange=\"updateStatus('${item.id}', 'risks', this.value)\" class=\"px-2 py-1 bg-[#f0f4f9] hover:bg-[#e2e8f0] text-[#1f1f1f] text-xs font-medium rounded-lg cursor-pointer focus:outline-none focus:ring-1 focus:ring-[#0b57d0]\">\n                  <option value=\"Active\" ${item.status === 'Active' ? 'selected' : ''}>Active</option>\n                  <option value=\"Mitigated\" ${item.status === 'Mitigated' ? 'selected' : ''}>Mitigated</option>\n                  <option value=\"Resolved\" ${item.status === 'Resolved' ? 'selected' : ''}>Resolved</option>\n                </select>\n              </td>\n              <td class=\"py-3.5 align-top text-right whitespace-nowrap\">\n                <div class=\"flex items-center justify-end space-x-1\">\n                  <button onclick=\"openEditModal('${item.id}', 'risks')\" class=\"p-1.5 hover:bg-[#f0f4f9] rounded-md text-[#5f6368] hover:text-[#1f1f1f] transition\" title=\"Edit\">\n                    <svg class=\"w-3.5 h-3.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z\"></path></svg>\n                  </button>\n                  <button onclick=\"deleteEntry('${item.id}', 'risks')\" class=\"p-1.5 hover:bg-[#fce8e6] rounded-md text-[#5f6368] hover:text-[#d93025] transition\" title=\"Delete\">\n                    <svg class=\"w-3.5 h-3.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16\"></path></svg>\n                  </button>\n                </div>\n              </td>\n            `;\n            tbody.appendChild(row);\n          });\n        }\n      }\n    }\n\n    // Switch between Decision and Risk modes\n    function switchTab(tab) {\n      activeTab = tab;\n      \n      const btnDecisions = document.getElementById('tab-decisions');\n      const btnRisks = document.getElementById('tab-risks');\n      \n      if (tab === 'decisions') {\n        btnDecisions.className = \"px-4 py-1.5 text-xs font-medium rounded-md transition duration-150 ease-in-out bg-white text-[#1f1f1f] shadow-sm\";\n        btnRisks.className = \"px-4 py-1.5 text-xs font-medium rounded-md transition duration-150 ease-in-out text-[#5f6368] hover:text-[#1f1f1f]\";\n      } else {\n        btnDecisions.className = \"px-4 py-1.5 text-xs font-medium rounded-md transition duration-150 ease-in-out text-[#5f6368] hover:text-[#1f1f1f]\";\n        btnRisks.className = \"px-4 py-1.5 text-xs font-medium rounded-md transition duration-150 ease-in-out bg-white text-[#1f1f1f] shadow-sm\";\n      }\n      \n      render();\n    }\n\n    function handleSearch() {\n      render();\n    }\n\n    // Populate the dropdown selector\n    function populateOwnerSelect() {\n      const select = document.getElementById('form-owner');\n      select.innerHTML = teamMembers.map(m => `<option value=\"${m.name}\">${m.name}</option>`).join('');\n    }\n\n    // Form Overlay Controllers\n    function openAddModal() {\n      isModalOpen = true;\n      document.getElementById('form-id').value = '';\n      document.getElementById('form-type').value = activeTab;\n      \n      document.getElementById('form-title').value = '';\n      document.getElementById('form-notes').value = '';\n      document.getElementById('form-mitigation').value = '';\n      \n      const today = new Date().toISOString().split('T')[0];\n      document.getElementById('form-date').value = today;\n      \n      populateOwnerSelect();\n      \n      const statusSelect = document.getElementById('form-status');\n      if (activeTab === 'decisions') {\n        document.getElementById('modal-title').textContent = 'Log New Decision';\n        document.getElementById('lbl-title').textContent = 'Decision / Proposed Alignment';\n        document.getElementById('decision-only-fields').classList.remove('hidden');\n        document.getElementById('risk-only-fields').classList.add('hidden');\n        \n        statusSelect.innerHTML = `\n          <option value=\"Proposed\">Proposed</option>\n          <option value=\"Approved\">Approved</option>\n          <option value=\"Rejected\">Rejected</option>\n        `;\n        statusSelect.value = \"Proposed\";\n      } else {\n        document.getElementById('modal-title').textContent = 'Log New Risk';\n        document.getElementById('lbl-title').textContent = 'Identified Risk & Potential Impact';\n        document.getElementById('decision-only-fields').classList.add('hidden');\n        document.getElementById('risk-only-fields').classList.remove('hidden');\n        \n        statusSelect.innerHTML = `\n          <option value=\"Active\">Active</option>\n          <option value=\"Mitigated\">Mitigated</option>\n          <option value=\"Resolved\">Resolved</option>\n        `;\n        statusSelect.value = \"Active\";\n      }\n      \n      document.getElementById('modal-backdrop').classList.remove('hidden');\n      document.getElementById('modal-backdrop').classList.add('flex');\n    }\n\n    function openEditModal(id, type) {\n      isModalOpen = true;\n      document.getElementById('form-id').value = id;\n      document.getElementById('form-type').value = type;\n      \n      populateOwnerSelect();\n      \n      const statusSelect = document.getElementById('form-status');\n      \n      if (type === 'decisions') {\n        const item = state.decisions.find(d => d.id === id);\n        if (!item) return;\n        \n        document.getElementById('modal-title').textContent = 'Edit Decision';\n        document.getElementById('lbl-title').textContent = 'Decision / Proposed Alignment';\n        document.getElementById('decision-only-fields').classList.remove('hidden');\n        document.getElementById('risk-only-fields').classList.add('hidden');\n        \n        document.getElementById('form-title').value = item.title;\n        document.getElementById('form-notes').value = item.notes || '';\n        document.getElementById('form-date').value = item.date;\n        document.getElementById('form-owner').value = item.owner;\n        \n        statusSelect.innerHTML = `\n          <option value=\"Proposed\">Proposed</option>\n          <option value=\"Approved\">Approved</option>\n          <option value=\"Rejected\">Rejected</option>\n        `;\n        statusSelect.value = item.status;\n      } else {\n        const item = state.risks.find(r => r.id === id);\n        if (!item) return;\n        \n        document.getElementById('modal-title').textContent = 'Edit Risk';\n        document.getElementById('lbl-title').textContent = 'Identified Risk & Potential Impact';\n        document.getElementById('decision-only-fields').classList.add('hidden');\n        document.getElementById('risk-only-fields').classList.remove('hidden');\n        \n        document.getElementById('form-title').value = item.title;\n        document.getElementById('form-mitigation').value = item.mitigation || '';\n        document.getElementById('form-severity').value = item.severity;\n        document.getElementById('form-owner').value = item.owner;\n        \n        statusSelect.innerHTML = `\n          <option value=\"Active\">Active</option>\n          <option value=\"Mitigated\">Mitigated</option>\n          <option value=\"Resolved\">Resolved</option>\n        `;\n        statusSelect.value = item.status;\n      }\n      \n      document.getElementById('modal-backdrop').classList.remove('hidden');\n      document.getElementById('modal-backdrop').classList.add('flex');\n    }\n\n    function closeModal() {\n      document.getElementById('modal-backdrop').classList.add('hidden');\n      document.getElementById('modal-backdrop').classList.remove('flex');\n      isModalOpen = false;\n    }\n\n    // Handle interactive submit\n    function handleFormSubmit(event) {\n      event.preventDefault();\n      \n      const id = document.getElementById('form-id').value;\n      const type = document.getElementById('form-type').value;\n      \n      const title = document.getElementById('form-title').value.trim();\n      const owner = document.getElementById('form-owner').value;\n      const status = document.getElementById('form-status').value;\n      \n      if (type === 'decisions') {\n        const date = document.getElementById('form-date').value;\n        const notes = document.getElementById('form-notes').value.trim();\n        \n        if (id) {\n          const index = state.decisions.findIndex(d => d.id === id);\n          if (index !== -1) {\n            state.decisions[index] = { ...state.decisions[index], title, owner, status, date, notes };\n          }\n        } else {\n          const newId = 'dec-' + Date.now();\n          state.decisions.push({ id: newId, title, owner, status, date, notes });\n        }\n      } else {\n        const severity = document.getElementById('form-severity').value;\n        const mitigation = document.getElementById('form-mitigation').value.trim();\n        \n        if (id) {\n          const index = state.risks.findIndex(r => r.id === id);\n          if (index !== -1) {\n            state.risks[index] = { ...state.risks[index], title, owner, status, severity, mitigation };\n          }\n        } else {\n          const newId = 'risk-' + Date.now();\n          state.risks.push({ id: newId, title, owner, status, severity, mitigation });\n        }\n      }\n      \n      saveSyncedState(state);\n      render();\n      closeModal();\n    }\n\n    // Direct Status Update from table selects\n    function updateStatus(id, type, newStatus) {\n      if (type === 'decisions') {\n        const index = state.decisions.findIndex(d => d.id === id);\n        if (index !== -1) {\n          state.decisions[index].status = newStatus;\n        }\n      } else {\n        const index = state.risks.findIndex(r => r.id === id);\n        if (index !== -1) {\n          state.risks[index].status = newStatus;\n        }\n      }\n      saveSyncedState(state);\n    }\n\n    // Delete Log Entry\n    function deleteEntry(id, type) {\n      if (!confirm('Are you sure you want to delete this log entry?')) return;\n      \n      if (type === 'decisions') {\n        state.decisions = state.decisions.filter(d => d.id !== id);\n      } else {\n        state.risks = state.risks.filter(r => r.id !== id);\n      }\n      \n      saveSyncedState(state);\n      render();\n    }\n\n    // Multiplayer State Synchronization Pipeline\n    async function loadSyncedState() {\n      if (!envId) {\n        // LocalStorage fallback for non-production / testing environments\n        const local = localStorage.getItem(syncKey);\n        if (local) {\n          try {\n            const parsed = JSON.parse(local);\n            if (parsed && (parsed.decisions || parsed.risks)) {\n              if (JSON.stringify(state) !== JSON.stringify(parsed)) {\n                state = parsed;\n                if (!isModalOpen) render();\n              }\n            }\n          } catch (e) {\n            console.error(\"Local storage error:\", e);\n          }\n        }\n        return;\n      }\n      \n      try {\n        const res = await fetch(`/api/sync/${envId}/${syncKey}`);\n        const json = await res.json();\n        if (json.data) {\n          if (JSON.stringify(state) !== JSON.stringify(json.data)) {\n            state = json.data;\n            if (!isModalOpen) {\n              render();\n            }\n          }\n        } else {\n          saveSyncedState(defaultState);\n        }\n      } catch (err) {\n        console.error(\"State syncer retrieve error:\", err);\n      }\n    }\n\n    async function saveSyncedState(newState) {\n      state = newState;\n      if (!envId) {\n        localStorage.setItem(syncKey, JSON.stringify(newState));\n        return;\n      }\n      try {\n        await fetch(`/api/sync/${envId}/${syncKey}`, {\n          method: \"POST\",\n          headers: { \"Content-Type\": \"application/json\" },\n          body: JSON.stringify({ data: newState })\n        });\n      } catch (err) {\n        console.error(\"State syncer publish error:\", err);\n      }\n    }\n\n    // Bootstrap Pipeline\n    window.addEventListener('DOMContentLoaded', () => {\n      loadSyncedState();\n      setInterval(loadSyncedState, 2000);\n      render();\n    });\n  </script>\n</body>\n</html>",
