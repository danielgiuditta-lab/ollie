    {
      "name": "index.html",
      "type": "code",
      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&family=Google+Sans+Text:wght@400;500&display=swap\" rel=\"stylesheet\">\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <style>\n    body {\n      font-family: 'Google Sans Text', sans-serif;\n      background-color: #ffffff;\n      color: #1f1f1f;\n    }\n    h1, h2, h3, h4, h5, button {\n      font-family: 'Google Sans', sans-serif;\n    }\n    ::-webkit-scrollbar {\n      width: 6px;\n      height: 6px;\n    }\n    ::-webkit-scrollbar-track {\n      background: transparent;\n    }\n    ::-webkit-scrollbar-thumb {\n      background: #e2e8f0;\n      border-radius: 3px;\n    }\n    ::-webkit-scrollbar-thumb:hover {\n      background: #cbd5e1;\n    }\n    .kanban-column {\n      min-height: 480px;\n    }\n    .dragging {\n      opacity: 0.4;\n      transform: scale(0.98);\n    }\n  </style>\n  <title>H2 Patient Experience Kanban Tracker</title>\n</head>\n<body class=\"p-6 bg-white text-[#1f1f1f]\">\n  <div class=\"max-w-7xl mx-auto space-y-6\">\n    \n    <!-- Controls Toolbar -->\n    <div class=\"flex flex-col md:flex-row md:items-center justify-between gap-4 pb-4 border-b border-[#e2e8f0]\">\n      <!-- Filters -->\n      <div class=\"flex items-center space-x-3\">\n        <!-- Search Input -->\n        <div class=\"relative\">\n          <input type=\"text\" id=\"search-input\" oninput=\"render()\" placeholder=\"Search milestones...\" class=\"w-48 md:w-64 pl-8 pr-3 py-1.5 text-xs bg-[#f0f4f9] hover:bg-[#e8f0fe] focus:bg-white border border-transparent focus:border-[#0b57d0] rounded-lg outline-none transition\">\n          <svg class=\"absolute left-2.5 top-2.5 w-3.5 h-3.5 text-[#5f6368]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\"></path>\n          </svg>\n        </div>\n\n        <!-- Assignee Filter -->\n        <select id=\"assignee-filter\" onchange=\"render()\" class=\"px-3 py-1.5 text-xs bg-[#f0f4f9] border border-transparent focus:border-[#0b57d0] rounded-lg outline-none text-[#1f1f1f]\">\n          <option value=\"ALL\">All Assignees</option>\n          <option value=\"Dr. Marcus Thorne\">Dr. Marcus Thorne</option>\n          <option value=\"Sarah Lin\">Sarah Lin</option>\n          <option value=\"Dr. Jason Miller\">Dr. Jason Miller</option>\n          <option value=\"Rachel Chang\">Rachel Chang</option>\n        </select>\n      </div>\n\n      <!-- Action Button -->\n      <button onclick=\"openModal()\" class=\"px-4 py-1.5 bg-[#0b57d0] hover:bg-[#0842a0] text-white text-xs font-medium rounded-lg transition duration-150 flex items-center space-x-1.5 shadow-sm\">\n        <span class=\"text-sm font-semibold\">+</span>\n        <span>Add H2 Milestone</span>\n      </button>\n    </div>\n\n    <!-- Kanban Columns Board Grid -->\n    <div class=\"grid grid-cols-1 md:grid-cols-4 gap-4\" id=\"kanban-grid\">\n      <!-- Dynamically generated columns -->\n    </div>\n  </div>\n\n  <!-- Add/Edit Modal -->\n  <div id=\"modal-backdrop\" class=\"fixed inset-0 bg-black/20 backdrop-blur-[1px] hidden items-center justify-center z-50\">\n    <div class=\"bg-white rounded-xl border border-[#e2e8f0] w-full max-w-md p-6 space-y-4 shadow-lg\">\n      <div class=\"flex items-center justify-between border-b border-[#e2e8f0] pb-3\">\n        <h3 class=\"text-sm font-semibold text-[#1f1f1f]\">Add H2 Roadmap Task</h3>\n        <button onclick=\"closeModal()\" class=\"text-[#5f6368] hover:text-[#1f1f1f] p-1 rounded-md hover:bg-[#f0f4f9]\">\n          <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M6 18L18 6M6 6l12 12\"></path>\n          </svg>\n        </button>\n      </div>\n\n      <form onsubmit=\"handleFormSubmit(event)\" class=\"space-y-4\">\n        <div>\n          <label class=\"block text-xs font-medium text-[#5f6368] mb-1\">Milestone Description</label>\n          <input type=\"text\" id=\"form-title\" required placeholder=\"e.g. Bedside Tablet Lab Result View\" class=\"w-full px-3 py-2 text-xs border border-[#e2e8f0] rounded-lg focus:border-[#0b57d0] outline-none\">\n        </div>\n\n        <div>\n          <label class=\"block text-xs font-medium text-[#5f6368] mb-1\">Care Stage (Column)</label>\n          <select id=\"form-stage\" required class=\"w-full px-3 py-2 text-xs border border-[#e2e8f0] rounded-lg focus:border-[#0b57d0] outline-none bg-white\">\n            <option value=\"triage\">Intake & Triage</option>\n            <option value=\"diagnostics\">Diagnostics & Labs</option>\n            <option value=\"surgery\">Specialized & Surgery</option>\n            <option value=\"discharge\">Discharge & Post-Acute</option>\n          </select>\n        </div>\n\n        <div>\n          <label class=\"block text-xs font-medium text-[#5f6368] mb-1\">Assigned Lead</label>\n          <select id=\"form-assignee\" required class=\"w-full px-3 py-2 text-xs border border-[#e2e8f0] rounded-lg focus:border-[#0b57d0] outline-none bg-white\">\n            <option value=\"Dr. Marcus Thorne\">Dr. Marcus Thorne</option>\n            <option value=\"Sarah Lin\">Sarah Lin</option>\n            <option value=\"Dr. Jason Miller\">Dr. Jason Miller</option>\n            <option value=\"Rachel Chang\">Rachel Chang</option>\n          </select>\n        </div>\n\n        <div>\n          <label class=\"block text-xs font-medium text-[#5f6368] mb-1\">Target Completion Date</label>\n          <input type=\"date\" id=\"form-date\" required class=\"w-full px-3 py-2 text-xs border border-[#e2e8f0] rounded-lg focus:border-[#0b57d0] outline-none\">\n        </div>\n\n        <div class=\"flex justify-end space-x-2 pt-3 border-t border-[#e2e8f0]\">\n          <button type=\"button\" onclick=\"closeModal()\" class=\"px-4 py-2 bg-[#f0f4f9] hover:bg-[#e2e8f0] text-xs font-medium rounded-lg\">Cancel</button>\n          <button type=\"submit\" class=\"px-4 py-2 bg-[#0b57d0] hover:bg-[#0842a0] text-white text-xs font-medium rounded-lg\">Save Milestone</button>\n        </div>\n      </form>\n    </div>\n  </div>\n\n  <script>\n    const teamMembers = [\n      { name: \"Dr. Marcus Thorne\", avatar: \"/people/dr_marcus_thorne.jpg\", initials: \"MT\", bg: \"#e8f0fe\", text: \"#1a73e8\" },\n      { name: \"Sarah Lin\", avatar: \"/people/sarah_lin.jpg\", initials: \"SL\", bg: \"#fce8e6\", text: \"#d93025\" },\n      { name: \"Dr. Jason Miller\", avatar: \"/people/dr_jason_miller.jpg\", initials: \"JM\", bg: \"#e6f4ea\", text: \"#137333\" },\n      { name: \"Rachel Chang\", avatar: \"/people/rachel_chang.jpg\", initials: \"RC\", bg: \"#fef7e0\", text: \"#b06000\" }\n    ];\n\n    const columns = [\n      { id: \"triage\", title: \"Intake & Triage\", countBg: \"bg-blue-100 text-blue-700\" },\n      { id: \"diagnostics\", title: \"Diagnostics & Labs\", countBg: \"bg-amber-100 text-amber-700\" },\n      { id: \"surgery\", title: \"Specialized & Surgery\", countBg: \"bg-purple-100 text-purple-700\" },\n      { id: \"discharge\", title: \"Discharge & Outpatient\", countBg: \"bg-emerald-100 text-emerald-700\" }\n    ];\n\n    let tasks = [\n      {\n        id: \"task-1\",\n        title: \"Implement Emergency Severity Index (ESI 1-5) automated EHR intake tag\",\n        stage: \"triage\",\n        assignee: \"Dr. Marcus Thorne\",\n        date: \"2026-07-28\"\n      },\n      {\n        id: \"task-2\",\n        title: \"Digital Kiosk Self-Registration Protocol for ED arrivals\",\n        stage: \"triage\",\n        assignee: \"Sarah Lin\",\n        date: \"2026-08-05\"\n      },\n      {\n        id: \"task-3\",\n        title: \"Reduce median triage-to-bed time from 48 minutes to < 18 minutes\",\n        stage: \"diagnostics\",\n        assignee: \"Dr. Jason Miller\",\n        date: \"2026-07-22\"\n      },\n      {\n        id: \"task-4\",\n        title: \"Biomarker & Blood Panel Rapid Result Alerts on mobile gateway\",\n        stage: \"diagnostics\",\n        assignee: \"Rachel Chang\",\n        date: \"2026-07-30\"\n      },\n      {\n        id: \"task-5\",\n        title: \"Digital SBAR Care Handoff checklist mandatory before Ward Transfer\",\n        stage: \"surgery\",\n        assignee: \"Rachel Chang\",\n        date: \"2026-08-01\"\n      },\n      {\n        id: \"task-6\",\n        title: \"Automated Family Waiting Status Board in PACU surgical center\",\n        stage: \"surgery\",\n        assignee: \"Sarah Lin\",\n        date: \"2026-08-12\"\n      },\n      {\n        id: \"task-7\",\n        title: \"Streamlined Digital Discharge & Post-Acute Transport Enablement\",\n        stage: \"discharge\",\n        assignee: \"Dr. Jason Miller\",\n        date: \"2026-07-16\"\n      }\n    ];\n\n    function getMember(name) {\n      return teamMembers.find(m => m.name === name) || teamMembers[0];\n    }\n\n    function renderMemberAvatar(name) {\n      const m = getMember(name);\n      return `\n        <div class=\"flex items-center space-x-1.5\">\n          <img src=\"${m.avatar}\" onerror=\"this.outerHTML='<div class=\\\\'w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-bold\\\\' style=\\\\'background-color:${m.bg};color:${m.text}\\\\'>${m.initials}</div>'\" class=\"w-5 h-5 rounded-full object-cover border border-slate-200\">\n          <span class=\"text-xs text-[#5f6368] font-medium\">${m.name}</span>\n        </div>\n      `;\n    }\n\n    let draggedTaskId = null;\n\n    function handleDragStart(e, id) {\n      draggedTaskId = id;\n      e.target.classList.add('dragging');\n    }\n\n    function handleDragEnd(e) {\n      e.target.classList.remove('dragging');\n      draggedTaskId = null;\n    }\n\n    function handleDragOver(e) {\n      e.preventDefault();\n    }\n\n    function handleDrop(e, stageId) {\n      e.preventDefault();\n      if (!draggedTaskId) return;\n      const index = tasks.findIndex(t => t.id === draggedTaskId);\n      if (index !== -1) {\n        tasks[index].stage = stageId;\n        saveState();\n        render();\n      }\n    }\n\n    function saveState() {\n      try {\n        localStorage.setItem(\"h2_kanban_tasks\", JSON.stringify(tasks));\n      } catch (err) {}\n    }\n\n    function loadState() {\n      try {\n        const saved = localStorage.getItem(\"h2_kanban_tasks\");\n        if (saved) {\n          tasks = JSON.parse(saved);\n        }\n      } catch (err) {}\n    }\n\n    function render() {\n      const query = document.getElementById('search-input').value.toLowerCase().trim();\n      const assigneeFilter = document.getElementById('assignee-filter').value;\n      const grid = document.getElementById('kanban-grid');\n      grid.innerHTML = '';\n\n      columns.forEach(col => {\n        const colTasks = tasks.filter(t => {\n          const matchesStage = t.stage === col.id;\n          const matchesQuery = t.title.toLowerCase().includes(query) || t.assignee.toLowerCase().includes(query);\n          const matchesAssignee = assigneeFilter === 'ALL' || t.assignee === assigneeFilter;\n          return matchesStage && matchesQuery && matchesAssignee;\n        });\n\n        const colEl = document.createElement('div');\n        colEl.className = \"flex flex-col bg-[#f0f4f9] rounded-xl p-3 border border-[#e2e8f0] kanban-column\";\n        colEl.ondragover = handleDragOver;\n        colEl.ondrop = (e) => handleDrop(e, col.id);\n\n        let cardsHtml = '';\n        if (colTasks.length === 0) {\n          cardsHtml = `<div class=\"p-4 text-center text-xs text-[#5f6368] border border-dashed border-slate-300 rounded-lg bg-white/50\">No milestones in this stage</div>`;\n        } else {\n          colTasks.forEach(task => {\n            cardsHtml += `\n              <div draggable=\"true\" ondragstart=\"handleDragStart(event, '${task.id}')\" ondragend=\"handleDragEnd(event)\" class=\"bg-white rounded-lg p-3 border border-[#e2e8f0] shadow-sm hover:border-[#0b57d0] transition cursor-grab active:cursor-grabbing space-y-3\">\n                <div class=\"text-xs font-medium text-[#1f1f1f] leading-snug\">${escapeHTML(task.title)}</div>\n                <div class=\"flex items-center justify-between pt-1 border-t border-slate-100\">\n                  ${renderMemberAvatar(task.assignee)}\n                  <span class=\"text-[11px] text-[#5f6368] font-mono\">${escapeHTML(task.date)}</span>\n                </div>\n              </div>\n            `;\n          });\n        }\n\n        colEl.innerHTML = `\n          <div class=\"flex items-center justify-between pb-3 mb-2 border-b border-slate-200\">\n            <h4 class=\"text-xs font-semibold text-[#1f1f1f] uppercase tracking-wider\">${col.title}</h4>\n            <span class=\"px-2 py-0.5 rounded-full text-[11px] font-semibold ${col.countBg}\">${colTasks.length}</span>\n          </div>\n          <div class=\"space-y-2.5 flex-1 overflow-y-auto\">\n            ${cardsHtml}\n          </div>\n        `;\n\n        grid.appendChild(colEl);\n      });\n    }\n\n    function escapeHTML(str) {\n      if (!str) return '';\n      return str.replace(/&/g, \"&amp;\").replace(/</g, \"&lt;\").replace(/>/g, \"&gt;\").replace(/\"/g, \"&quot;\").replace(/'/g, \"&#039;\");\n    }\n\n    function openModal() {\n      document.getElementById('modal-backdrop').classList.remove('hidden');\n      document.getElementById('modal-backdrop').classList.add('flex');\n      const today = new Date().toISOString().split('T')[0];\n      document.getElementById('form-date').value = today;\n    }\n\n    function closeModal() {\n      document.getElementById('modal-backdrop').classList.add('hidden');\n      document.getElementById('modal-backdrop').classList.remove('flex');\n    }\n\n    function handleFormSubmit(e) {\n      e.preventDefault();\n      const title = document.getElementById('form-title').value.trim();\n      const stage = document.getElementById('form-stage').value;\n      const assignee = document.getElementById('form-assignee').value;\n      const date = document.getElementById('form-date').value;\n\n      if (title) {\n        tasks.push({\n          id: 'task-' + Date.now(),\n          title,\n          stage,\n          assignee,\n          date\n        });\n        saveState();\n        render();\n        closeModal();\n      }\n    }\n\n    window.addEventListener('DOMContentLoaded', () => {\n      loadState();\n      render();\n    });\n  </script>\n</body>\n</html>",
