  "sandboxFiles": [
    {
      "name": "index.html",
      "type": "code",
      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Project Ollie Task Tracker</title>\n  \n  <!-- Tailwind CSS CDN -->\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  \n  <!-- Google Fonts -->\n  <link href=\"https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&family=Google+Sans+Text:wght@400;500&display=swap\" rel=\"stylesheet\">\n  \n  <style>\n    :root {\n      --gemini-rail-icon-gap: 0px;\n      --gemini-side-panel-padding-left: 16px;\n      --gemini-side-panel-padding-right: 16px;\n      --gemini-header-padding-left: 10px;\n      --gemini-header-padding-right: 12px;\n      --gemini-header-elements-gap: 8px;\n      \n      /* Material Design 3 (M3) Tokens */\n      --primary: #0b57d0;\n      --on-primary: #ffffff;\n      --primary-container: #d3e3fd;\n      --surface: #ffffff;\n      --surface-container: #f0f4f9;\n      --outline: #747775;\n      --text-main: #131314;\n    }\n\n    body {\n      font-family: 'Google Sans Text', sans-serif;\n      background-color: var(--surface);\n      color: var(--text-main);\n      margin: 0;\n      padding: 0;\n    }\n\n    h1, h2, h3 {\n      font-family: 'Google Sans', sans-serif;\n    }\n\n    .column-height {\n      min-height: calc(100vh - 240px);\n    }\n\n    .drag-over {\n      background-color: #e3ebf7 !important;\n      border: 2px dashed var(--primary);\n    }\n  </style>\n</head>\n<body class=\"p-6 bg-[#ffffff]\">\n\n  <!-- Main Container -->\n  <div class=\"max-w-7xl mx-auto\">\n    \n    <!-- Top Workspace Header -->\n    <header class=\"flex flex-col md:flex-row md:items-center md:justify-between pb-6 border-b border-gray-200 mb-6\">\n      <div>\n        <div class=\"flex items-center gap-2\">\n          <span class=\"inline-block w-3 h-3 rounded-full bg-[#0b57d0] animate-pulse\"></span>\n          <h1 class=\"text-2xl font-medium tracking-tight text-[#131314]\">Project Ollie Task Board</h1>\n        </div>\n        <p class=\"text-sm text-gray-500 mt-1\">\n          Workspace: <span id=\"workspace-name\" class=\"font-medium text-gray-700\">Loading Workspace...</span>\n        </p>\n      </div>\n\n      <!-- Sync Status -->\n      <div class=\"flex items-center gap-2 mt-3 md:mt-0 bg-[#f0f4f9] px-3 py-1.5 rounded-full text-xs text-gray-600 border border-gray-200\">\n        <svg class=\"w-4 h-4 text-[#0b57d0] animate-spin\" id=\"sync-spinner\" fill=\"none\" viewBox=\"0 0 24 24\">\n          <circle class=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" stroke-width=\"4\"></circle>\n          <path class=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\"></path>\n        </svg>\n        <span id=\"sync-status\">Syncing real-time changes</span>\n      </div>\n    </header>\n\n    <!-- Radical Simplicity Add Task Bar -->\n    <section class=\"bg-[#f0f4f9] p-4 rounded-xl border border-gray-200 mb-8\">\n      <h2 class=\"text-sm font-medium text-[#131314] mb-3\">Add New Team Task</h2>\n      <form id=\"add-task-form\" class=\"flex flex-col sm:flex-row gap-3\">\n        <input \n          type=\"text\" \n          id=\"task-title\" \n          required\n          placeholder=\"What needs to be done? (e.g. Implement Spanner cycle-detection)\" \n          class=\"flex-1 bg-white px-4 py-2 text-sm rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-[#0b57d0] text-gray-800\"\n        />\n        \n        <select \n          id=\"task-assignee\" \n          class=\"bg-white px-3 py-2 text-sm rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-[#0b57d0] text-gray-700\"\n        >\n          <!-- Filled dynamically via JS -->\n        </select>\n\n        <button \n          type=\"submit\" \n          class=\"bg-[#0b57d0] hover:bg-[#0842a0] text-white px-5 py-2 text-sm font-medium rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#0b57d0]\"\n        >\n          Add Task\n        </button>\n      </form>\n    </section>\n\n    <!-- 3-Column Simple Kanban Grid -->\n    <main class=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n      \n      <!-- TO DO COLUMN -->\n      <div class=\"bg-[#f0f4f9] rounded-xl border border-gray-200 flex flex-col p-4\">\n        <div class=\"flex justify-between items-center pb-3 border-b border-gray-200 mb-4\">\n          <h3 class=\"font-medium text-[#131314] flex items-center gap-2\">\n            To Do\n            <span id=\"count-todo\" class=\"bg-gray-200 text-gray-700 text-xs px-2.5 py-0.5 rounded-full font-bold\">0</span>\n          </h3>\n        </div>\n        <div id=\"col-todo\" class=\"column-height flex flex-col gap-3\" ondragover=\"allowDrop(event)\" ondrop=\"drop(event, 'todo')\" ondragleave=\"dragLeave(event)\">\n          <!-- Cards go here -->\n        </div>\n      </div>\n\n      <!-- IN PROGRESS COLUMN -->\n      <div class=\"bg-[#f0f4f9] rounded-xl border border-gray-200 flex flex-col p-4\">\n        <div class=\"flex justify-between items-center pb-3 border-b border-gray-200 mb-4\">\n          <h3 class=\"font-medium text-[#131314] flex items-center gap-2\">\n            In Progress\n            <span id=\"count-inprogress\" class=\"bg-[#d3e3fd] text-[#0b57d0] text-xs px-2.5 py-0.5 rounded-full font-bold\">0</span>\n          </h3>\n        </div>\n        <div id=\"col-inprogress\" class=\"column-height flex flex-col gap-3\" ondragover=\"allowDrop(event)\" ondrop=\"drop(event, 'inprogress')\" ondragleave=\"dragLeave(event)\">\n          <!-- Cards go here -->\n        </div>\n      </div>\n\n      <!-- DONE COLUMN -->\n      <div class=\"bg-[#f0f4f9] rounded-xl border border-gray-200 flex flex-col p-4\">\n        <div class=\"flex justify-between items-center pb-3 border-b border-gray-200 mb-4\">\n          <h3 class=\"font-medium text-[#131314] flex items-center gap-2\">\n            Done\n            <span id=\"count-done\" class=\"bg-green-100 text-green-700 text-xs px-2.5 py-0.5 rounded-full font-bold\">0</span>\n          </h3>\n        </div>\n        <div id=\"col-done\" class=\"column-height flex flex-col gap-3\" ondragover=\"allowDrop(event)\" ondrop=\"drop(event, 'done')\" ondragleave=\"dragLeave(event)\">\n          <!-- Cards go here -->\n        </div>\n      </div>\n\n    </main>\n  </div>\n\n  <!-- JavaScript and Workspace Sync Integrations -->\n  <script>\n    // Real Team Members Context Database\n    const teamMembers = [\n      { name: \"Stephanie Goodson\", email: \"sgoodson@google.com\", avatar: \"https://lh3.googleusercontent.com/a-/ALV-UjXhSTeKdBDfDYWa6uS5J89rBh2uJHVV8OHoEUKYEe8AVFjY-4Q=s64\" },\n      { name: \"Chris Carroll\", email: \"cdcarroll@google.com\", avatar: \"https://lh3.googleusercontent.com/a-/ALV-UjVbB5SNQqui8-Dhh4ttI-p8lTdndJGcwTKlRrPnnNuKpJEXlKqF=s64\" },\n      { name: \"Jannica Robertson\", email: \"jannicar@google.com\", avatar: \"https://lh3.googleusercontent.com/a-/ALV-UjWDycqL54QiGjUCQolQXjRQ80GsUFizqLOjmWN5j5IAy9-NLFIO=s64\" },\n      { name: \"Frank Tisellano\", email: \"ftj@google.com\", avatar: \"https://lh3.googleusercontent.com/a-/ALV-UjWIXtfhCFx8S8zhFpLAaF9NZSiDJZmtDjpzW8DRqDnltb-otP9-=s64\" },\n      { name: \"Megan Bruce\", email: \"meganbruce@google.com\", avatar: \"https://lh3.googleusercontent.com/a-/ALV-UjW14QaUGF52yVyOkgsoQgDd7YxKtA3flS0Y-FgQSpfMlPB5Cib_=s64\" },\n      { name: \"Ajay Yadav\", email: \"yadavajay@google.com\", avatar: \"https://lh3.googleusercontent.com/a-/ALV-UjW5ytDzOzOxOMnVKGMTlZFIQFZGQE-F3hF9WT2C3_8rKFkSa6V4xQ=s64\" },\n      { name: \"Belinda Preno\", email: \"belindapreno@google.com\", avatar: \"https://lh3.googleusercontent.com/a-/ALV-UjW8kkayF4FN3ib50ZpJsNFIMcSF9CLOgEcXNjlG9yhQ2xy1dL2q=s64\" },\n      { name: \"Emily Thomas\", email: \"emilyjthomas@google.com\", avatar: \"https://lh3.googleusercontent.com/a-/ALV-UjVsXrPitMvyKTee1jfDjpODeKXAkN05NFP-MujtVh_GF6LFi1qw=s64\" },\n      { name: \"Daniel Giuditta\", email: \"danielgiuditta@google.com\", avatar: \"https://lh3.googleusercontent.com/a/ACg8ocI4XtQJyOGEbExqDChL5Jutn2AfMdv-Yaq9Pbdd1NMuBb-qO08=s64\" },\n      { name: \"Zhengrong Ji\", email: \"jizr@google.com\", avatar: \"https://lh3.googleusercontent.com/a-/ALV-UjWcXn2VmhyBKHwqviKOHkMtMPnIR1VFjOlNEyIMFrFI2C0Pt0Zj=s64\" },\n      { name: \"Ryan Spohn\", email: \"rspohn@google.com\", avatar: \"https://lh3.googleusercontent.com/a-/ALV-UjVbqXCvGLcBpDuCdv05JUnymeuoDYoUYTELHxdY4k_5BhnH6GWHMg=s64\" },\n      { name: \"Laurence Fahey\", email: \"laurencefahey@google.com\", avatar: \"https://lh3.googleusercontent.com/a/ACg8ocLLL2cXiri5iV3mBRXg2mYrij2OJg28l3nTJrtWU5YQlotT2iUH=s64\" },\n      { name: \"Ian Mendiola\", email: \"ianmendiola@google.com\", avatar: \"https://lh3.googleusercontent.com/a-/ALV-UjUP0nZZSsC7tRQg_3si0rRn-TJyMoD8j0kfQm3I-HdLEIVQYBsG=s64\" },\n      { name: \"David Wurtz\", email: \"wurtz@google.com\", avatar: \"https://lh3.googleusercontent.com/a-/ALV-UjW7KVh0yVuDb5C5TdRwGD7YYrY9iwTZzjNklnwKjpKGKeTFhayw=s64\" }\n    ];\n\n    // Initial default state tasks if synchronized space is empty\n    const defaultTasks = [\n      { id: \"task-1\", title: \"Implement Spanner cycle-detection CTE in CreateSubTask\", status: \"todo\", assigneeEmail: \"ianmendiola@google.com\" },\n      { id: \"task-2\", title: \"Design hybrid semantic + BM25 retrieval for Memory Service\", status: \"todo\", assigneeEmail: \"jizr@google.com\" },\n      { id: \"task-3\", title: \"Sobi Harness: Add agent_extension.go permission checking\", status: \"inprogress\", assigneeEmail: \"cdcarroll@google.com\" },\n      { id: \"task-4\", title: \"Create UX Research Interview plan for baseline workflows\", status: \"inprogress\", assigneeEmail: \"sgoodson@google.com\" },\n      { id: \"task-5\", title: \"DDL: Setup FactualFacts & MemoryACLs Spanner tables\", status: \"done\", assigneeEmail: \"rspohn@google.com\" },\n      { id: \"task-6\", title: \"Draft High Level Design (HLD) document for Project Ollie\", status: \"done\", assigneeEmail: \"ftj@google.com\" }\n    ];\n\n    let state = {\n      tasks: []\n    };\n\n    let localStateString = \"\";\n    const envId = window.__sandboxEnvId;\n    const syncKey = \"project_ollie_board_state\";\n\n    // Setup initial workspace title\n    document.getElementById(\"workspace-name\").innerText = window.__sandboxWorkspaceName || \"Default Workspace\";\n\n    // Build Assignee Dropdown Options\n    const assigneeSelect = document.getElementById(\"task-assignee\");\n    teamMembers.forEach(member => {\n      const option = document.createElement(\"option\");\n      option.value = member.email;\n      option.textContent = member.name;\n      assigneeSelect.appendChild(option);\n    });\n\n    // Load Synced State\n    async function loadSyncedState() {\n      if (!envId) {\n        // Fallback to local storage if not running inside the platform sandbox\n        const localData = localStorage.getItem(syncKey);\n        if (localData) {\n          updateUI(JSON.parse(localData));\n        } else {\n          updateUI({ tasks: defaultTasks });\n        }\n        showSyncCompleted();\n        return;\n      }\n\n      try {\n        const res = await fetch(`/api/sync/${envId}/${syncKey}`);\n        const json = await res.json();\n        if (json.data && json.data.tasks) {\n          updateUI(json.data);\n        } else {\n          // Initialize with default tasks if empty\n          await saveSyncedState({ tasks: defaultTasks });\n          updateUI({ tasks: defaultTasks });\n        }\n        showSyncCompleted();\n      } catch (err) {\n        console.error(\"Failed to load synced state:\", err);\n        showSyncError();\n      }\n    }\n\n    // Save Synced State\n    async function saveSyncedState(newState) {\n      if (!envId) {\n        localStorage.setItem(syncKey, JSON.stringify(newState));\n        updateUI(newState);\n        return;\n      }\n\n      showSyncing();\n      try {\n        await fetch(`/api/sync/${envId}/${syncKey}`, {\n          method: \"POST\",\n          headers: { \"Content-Type\": \"application/json\" },\n          body: JSON.stringify({ data: newState })\n        });\n        updateUI(newState);\n        showSyncCompleted();\n      } catch (err) {\n        console.error(\"Failed to save synced state:\", err);\n        showSyncError();\n      }\n    }\n\n    function updateUI(newState) {\n      const newStateString = JSON.stringify(newState);\n      if (newStateString === localStateString) return; // Prevent unnecessary redraws\n      localStateString = newStateString;\n      state = newState;\n      renderBoard();\n    }\n\n    function renderBoard() {\n      const columns = {\n        todo: document.getElementById(\"col-todo\"),\n        inprogress: document.getElementById(\"col-inprogress\"),\n        done: document.getElementById(\"col-done\")\n      };\n\n      // Clear all columns\n      Object.values(columns).forEach(col => col.innerHTML = \"\");\n\n      // Counter monitors\n      const counts = { todo: 0, inprogress: 0, done: 0 };\n\n      state.tasks.forEach(task => {\n        counts[task.status]++;\n        const assignee = teamMembers.find(m => m.email === task.assigneeEmail) || { name: \"Unassigned\", avatar: \"\" };\n        \n        // Build beautiful minimalist card\n        const card = document.createElement(\"div\");\n        card.id = task.id;\n        card.draggable = true;\n        card.className = \"bg-white p-4 rounded-xl border border-gray-200 shadow-sm hover:border-gray-400 transition-all cursor-grab active:cursor-grabbing relative group\";\n        card.setAttribute(\"ondragstart\", `drag(event, '${task.id}')`);\n\n        // Avatar template rule check\n        const avatarImg = assignee.avatar \n          ? `<img src=\"${assignee.avatar}\" alt=\"${assignee.name}\" class=\"w-5 h-5 rounded-full object-cover\">`\n          : `<div class=\"w-5 h-5 rounded-full bg-blue-100 flex items-center justify-center text-[10px] font-bold text-blue-600\">${assignee.name.split(\" \").map(n => n[0]).join(\"\")}</div>`;\n\n        // Left/Right control buttons for fluid interactive modifications\n        let navButtons = ``;\n        if (task.status === \"todo\") {\n          navButtons = `<button onclick=\"moveStatus('${task.id}', 'inprogress')\" class=\"p-1 rounded hover:bg-gray-100 text-gray-500 hover:text-blue-600\" title=\"Move to In Progress\">>→</button>`;\n        } else if (task.status === \"inprogress\") {\n          navButtons = `\n            <button onclick=\"moveStatus('${task.id}', 'todo')\" class=\"p-1 rounded hover:bg-gray-100 text-gray-500 hover:text-blue-600\" title=\"Move to To Do\">←</button>\n            <button onclick=\"moveStatus('${task.id}', 'done')\" class=\"p-1 rounded hover:bg-gray-100 text-gray-500 hover:text-blue-600\" title=\"Move to Done\">>→</button>\n          `;\n        } else if (task.status === \"done\") {\n          navButtons = `<button onclick=\"moveStatus('${task.id}', 'inprogress')\" class=\"p-1 rounded hover:bg-gray-100 text-gray-500 hover:text-blue-600\" title=\"Move to In Progress\">←</button>`;\n        }\n\n        card.innerHTML = `\n          <div class=\"flex flex-col gap-3\">\n            <p class=\"text-sm font-normal text-gray-800 leading-snug pr-6\">${escapeHtml(task.title)}</p>\n            \n            <div class=\"flex items-center justify-between border-t border-gray-100 pt-3\">\n              <div class=\"flex items-center gap-1.5\">\n                ${avatarImg}\n                <span class=\"text-xs text-gray-500 font-medium\">${assignee.name}</span>\n              </div>\n              \n              <div class=\"flex items-center gap-1\">\n                ${navButtons}\n                <button onclick=\"deleteTask('${task.id}')\" class=\"p-1 rounded hover:bg-red-50 text-gray-400 hover:text-red-500 transition-colors\" title=\"Delete task\">\n                  <svg class=\"w-3.5 h-3.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-16v1a1 1 0 001 1h3m-6 0a1 1 0 001-1V4a1 1 0 00-1-1h-3a1 1 0 00-1 1v1m-6 0h18\"></path>\n                  </svg>\n                </button>\n              </div>\n            </div>\n          </div>\n        `;\n\n        if (columns[task.status]) {\n          columns[task.status].appendChild(card);\n        }\n      });\n\n      // Update indicators\n      document.getElementById(\"count-todo\").textContent = counts.todo;\n      document.getElementById(\"count-inprogress\").textContent = counts.inprogress;\n      document.getElementById(\"count-done\").textContent = counts.done;\n    }\n\n    // HTML sanitizer to prevent XSS injection\n    function escapeHtml(text) {\n      const div = document.createElement('div');\n      div.innerText = text;\n      return div.innerHTML;\n    }\n\n    // Interactive action triggers\n    async function moveStatus(taskId, newStatus) {\n      const updatedTasks = state.tasks.map(task => {\n        if (task.id === taskId) {\n          return { ...task, status: newStatus };\n        }\n        return task;\n      });\n      await saveSyncedState({ tasks: updatedTasks });\n    }\n\n    async function deleteTask(taskId) {\n      const updatedTasks = state.tasks.filter(task => task.id !== taskId);\n      await saveSyncedState({ tasks: updatedTasks });\n    }\n\n    // Add New Task Submissions\n    document.getElementById(\"add-task-form\").addEventListener(\"submit\", async (e) => {\n      e.preventDefault();\n      const titleInput = document.getElementById(\"task-title\");\n      const assigneeSelect = document.getElementById(\"task-assignee\");\n\n      const newTask = {\n        id: \"task-\" + Date.now(),\n        title: titleInput.value.trim(),\n        status: \"todo\",\n        assigneeEmail: assigneeSelect.value\n      };\n\n      const updatedTasks = [...state.tasks, newTask];\n      await saveSyncedState({ tasks: updatedTasks });\n\n      titleInput.value = \"\";\n    });\n\n    // HTML5 Drag and Drop Handlers\n    function drag(ev, taskId) {\n      ev.dataTransfer.setData(\"text/plain\", taskId);\n      ev.currentTarget.classList.add(\"opacity-50\");\n    }\n\n    function allowDrop(ev) {\n      ev.preventDefault();\n      const column = ev.currentTarget;\n      if (!column.classList.contains(\"drag-over\")) {\n        column.classList.add(\"drag-over\");\n      }\n    }\n\n    function dragLeave(ev) {\n      ev.currentTarget.classList.remove(\"drag-over\");\n    }\n\n    async function drop(ev, status) {\n      ev.preventDefault();\n      const column = ev.currentTarget;\n      column.classList.remove(\"drag-over\");\n      \n      const taskId = ev.dataTransfer.getData(\"text/plain\");\n      const card = document.getElementById(taskId);\n      if (card) {\n        card.classList.remove(\"opacity-50\");\n      }\n\n      await moveStatus(taskId, status);\n    }\n\n    // Sync state feedback helper routines\n    function showSyncing() {\n      document.getElementById(\"sync-spinner\").classList.remove(\"hidden\");\n      document.getElementById(\"sync-status\").textContent = \"Saving modifications...\";\n    }\n\n    function showSyncCompleted() {\n      document.getElementById(\"sync-spinner\").classList.add(\"hidden\");\n      document.getElementById(\"sync-status\").textContent = \"All changes synchronized\";\n    }\n\n    function showSyncError() {\n      document.getElementById(\"sync-spinner\").classList.add(\"hidden\");\n      document.getElementById(\"sync-status\").textContent = \"Offline Mode / Connection Lost\";\n    }\n\n    // Short-poll state every 2 seconds to retrieve multiplayer changes live\n    loadSyncedState();\n    if (envId) {\n      setInterval(loadSyncedState, 2000);\n    }\n  </script>\n</body>\n</html>",
