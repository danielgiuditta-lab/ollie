      "name": "index.html",
      "type": "code",
      "mimeType": "text/html",
      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&family=Google+Sans+Text:wght@400;500&display=swap\" rel=\"stylesheet\">\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <style>\n    :root {\n      --gemini-rail-icon-gap: 0px;\n      --gemini-side-panel-padding-left: 16px;\n      --gemini-side-panel-padding-right: 16px;\n      --gemini-header-padding-left: 10px;\n      --gemini-header-padding-right: 12px;\n      --gemini-header-elements-gap: 8px;\n    }\n    body {\n      font-family: 'Google Sans Text', sans-serif;\n      background-color: #ffffff;\n      color: #1f1f1f;\n    }\n    h1, h2, h3, h4, h5, button {\n      font-family: 'Google Sans', sans-serif;\n    }\n  </style>\n  <title>Decision & Risk Log</title>\n</head>\n<body class=\"p-6 bg-white text-[#1f1f1f]\">\n  <div class=\"max-w-6xl mx-auto space-y-6\">\n    \n    <!-- Controls (Search & Filters) -->\n    <div class=\"flex flex-col sm:flex-row gap-3 justify-between items-center bg-[#f0f4f9] p-3 rounded-xl border border-slate-200\">\n      <div class=\"relative w-full sm:w-72\">\n        <input \n          type=\"text\" \n          id=\"search-input\" \n          placeholder=\"Search decisions...\" \n          oninput=\"renderDecisions()\"\n          class=\"w-full px-3 py-1.5 text-xs bg-white border border-[#747775] rounded-lg focus:outline-none focus:border-[#0b57d0] transition\"\n        >\n      </div>\n      <div class=\"flex gap-2 w-full sm:w-auto\">\n        <select \n          id=\"status-filter\" \n          onchange=\"renderDecisions()\"\n          class=\"flex-1 sm:flex-initial px-3 py-1.5 text-xs bg-white border border-[#747775] rounded-lg focus:outline-none focus:border-[#0b57d0] transition cursor-pointer\"\n        >\n          <option value=\"all\">All Statuses</option>\n          <option value=\"Proposed\">Proposed</option>\n          <option value=\"Approved\">Approved</option>\n          <option value=\"Deferred\">Deferred</option>\n        </select>\n        <select \n          id=\"owner-filter\" \n          onchange=\"renderDecisions()\"\n          class=\"flex-1 sm:flex-initial px-3 py-1.5 text-xs bg-white border border-[#747775] rounded-lg focus:outline-none focus:border-[#0b57d0] transition cursor-pointer\"\n        >\n          <option value=\"all\">All Owners</option>\n          <option value=\"dr_marcus_thorne@example.com\">Dr. Marcus Thorne</option>\n          <option value=\"sarah_lin@example.com\">Sarah Lin</option>\n          <option value=\"dr_jason_miller@example.com\">Dr. Jason Miller</option>\n          <option value=\"rachel_chang@example.com\">Rachel Chang</option>\n        </select>\n      </div>\n    </div>\n\n    <!-- Main Workspace Split Grid -->\n    <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n      \n      <!-- Decisions List & Grid Column -->\n      <div class=\"lg:col-span-2 border border-slate-200 rounded-xl overflow-hidden bg-white\">\n        <table class=\"w-full text-left border-collapse\">\n          <thead>\n            <tr class=\"bg-[#f0f4f9] border-b border-slate-200 text-xs font-medium text-[#444746]\">\n              <th class=\"px-4 py-3 w-28\">Date</th>\n              <th class=\"px-4 py-3\">Decision</th>\n              <th class=\"px-4 py-3 w-40\">Owner</th>\n              <th class=\"px-4 py-3 w-28\">Status</th>\n              <th class=\"px-4 py-3 w-12 text-center\"></th>\n            </tr>\n          </thead>\n          <tbody id=\"decisions-body\" class=\"divide-y divide-slate-100 text-sm\">\n            <!-- Dynamic Content -->\n          </tbody>\n        </table>\n        <div id=\"empty-state\" class=\"hidden p-8 text-center text-xs text-slate-500\">\n          No matching decisions found.\n        </div>\n      </div>\n\n      <!-- Log New Decision Column -->\n      <div class=\"border border-slate-200 rounded-xl p-5 bg-white space-y-4 h-fit\">\n        <h3 class=\"text-xs font-medium text-[#1f1f1f] border-b border-slate-100 pb-2 uppercase tracking-wider\">Log New Decision</h3>\n        <form id=\"decision-form\" class=\"space-y-4\">\n          <div class=\"space-y-1\">\n            <label class=\"text-[11px] font-medium text-[#444746]\">Decision Title</label>\n            <input \n              type=\"text\" \n              id=\"form-title\" \n              required \n              placeholder=\"e.g. Biomarker notification triggers\"\n              class=\"w-full px-3 py-2 text-xs bg-white border border-[#747775] rounded-lg focus:outline-none focus:border-[#0b57d0] transition\"\n            >\n          </div>\n          <div class=\"space-y-1\">\n            <label class=\"text-[11px] font-medium text-[#444746]\">Details & Context</label>\n            <textarea \n              id=\"form-details\" \n              rows=\"3\" \n              required\n              placeholder=\"Provide a concise summary of rationale or action plan...\"\n              class=\"w-full px-3 py-2 text-xs bg-white border border-[#747775] rounded-lg focus:outline-none focus:border-[#0b57d0] transition resize-none\"\n            ></textarea>\n          </div>\n          <div class=\"grid grid-cols-2 gap-3\">\n            <div class=\"space-y-1\">\n              <label class=\"text-[11px] font-medium text-[#444746]\">Owner</label>\n              <select \n                id=\"form-owner\" \n                class=\"w-full px-2 py-1.5 text-xs bg-white border border-[#747775] rounded-lg focus:outline-none focus:border-[#0b57d0] transition cursor-pointer\"\n              >\n                <option value=\"dr_marcus_thorne@example.com\">Dr. Marcus Thorne</option>\n                <option value=\"sarah_lin@example.com\">Sarah Lin</option>\n                <option value=\"dr_jason_miller@example.com\">Dr. Jason Miller</option>\n                <option value=\"rachel_chang@example.com\">Rachel Chang</option>\n              </select>\n            </div>\n            <div class=\"space-y-1\">\n              <label class=\"text-[11px] font-medium text-[#444746]\">Status</label>\n              <select \n                id=\"form-status\" \n                class=\"w-full px-2 py-1.5 text-xs bg-white border border-[#747775] rounded-lg focus:outline-none focus:border-[#0b57d0] transition cursor-pointer\"\n              >\n                <option value=\"Proposed\">Proposed</option>\n                <option value=\"Approved\">Approved</option>\n                <option value=\"Deferred\">Deferred</option>\n              </select>\n            </div>\n          </div>\n          <div class=\"space-y-1\">\n            <label class=\"text-[11px] font-medium text-[#444746]\">Decision Date</label>\n            <input \n              type=\"date\" \n              id=\"form-date\" \n              required\n              class=\"w-full px-3 py-2 text-xs bg-white border border-[#747775] rounded-lg focus:outline-none focus:border-[#0b57d0] transition cursor-pointer\"\n            >\n          </div>\n          <button \n            type=\"submit\" \n            class=\"w-full py-2 bg-[#0b57d0] hover:bg-[#0842a0] text-white text-xs font-medium rounded-lg transition\"\n          >\n            Record Decision\n          </button>\n        </form>\n      </div>\n\n    </div>\n  </div>\n\n  <script>\n    const envId = window.__sandboxEnvId;\n    const syncKey = \"team_decisions_log_v1\";\n    let decisions = [];\n\n    const members = {\n      \"dr_marcus_thorne@example.com\": { name: \"Dr. Marcus Thorne\", avatar: \"/people/dr_marcus_thorne.jpg\", initials: \"MT\" },\n      \"sarah_lin@example.com\": { name: \"Sarah Lin\", avatar: \"/people/sarah_lin.jpg\", initials: \"SL\" },\n      \"dr_jason_miller@example.com\": { name: \"Dr. Jason Miller\", avatar: \"/people/dr_jason_miller.jpg\", initials: \"JM\" },\n      \"rachel_chang@example.com\": { name: \"Rachel Chang\", avatar: \"/people/rachel_chang.jpg\", initials: \"RC\" }\n    };\n\n    function getDefaultDecisions() {\n      return [\n        {\n          id: \"dec-1\",\n          title: \"Biomarker Push Notifications Flow\",\n          details: \"Integrate direct mobile alerts (iOS/Android) as requested by oncology round tests when pathology outcomes return.\",\n          owner: \"rachel_chang@example.com\",\n          status: \"Approved\",\n          date: \"2026-07-12\"\n        },\n        {\n          id: \"dec-2\",\n          title: \"EHR Integration Pilot Scope\",\n          details: \"Limit native clinical database testing to 5 initial community pilot wards prior to full enterprise MDM launch.\",\n          owner: \"dr_jason_miller@example.com\",\n          status: \"Approved\",\n          date: \"2026-07-10\"\n        },\n        {\n          id: \"dec-3\",\n          title: \"Digital SBAR Checklist Handoff Gate\",\n          details: \"Mandate complete mobile checklist validation before patient is routed out of emergency triage.\",\n          owner: \"dr_marcus_thorne@example.com\",\n          status: \"Proposed\",\n          date: \"2026-07-14\"\n        },\n        {\n          id: \"dec-4\",\n          title: \"Offline Trial Caching Parameters\",\n          details: \"Limit native offline SQLite database state space to 500 active phase 1 and 2 biopharma criteria.\",\n          owner: \"sarah_lin@example.com\",\n          status: \"Proposed\",\n          date: \"2026-07-15\"\n        }\n      ];\n    }\n\n    function escapeHtml(str) {\n      if (!str) return '';\n      return str.replace(/&/g, \"&amp;\").replace(/</g, \"&lt;\").replace(/>/g, \"&gt;\").replace(/\"/g, \"&quot;\").replace(/'/g, \"&#039;\");\n    }\n\n    function renderAvatar(email) {\n      const m = members[email] || { name: \"Unassigned\", avatar: \"\", initials: \"U\" };\n      return `\n        <div class=\"flex items-center gap-1.5\">\n          <div class=\"relative w-5 h-5 rounded-full overflow-hidden bg-slate-200 flex-shrink-0 flex items-center justify-center\">\n            ${m.avatar ? `<img src=\"${m.avatar}\" class=\"w-full h-full object-cover\" onerror=\"this.style.display='none'\">` : ''}\n            <span class=\"absolute inset-0 flex items-center justify-center text-[9px] font-medium text-slate-600 bg-slate-200\">${m.initials}</span>\n          </div>\n          <span class=\"text-xs text-[#1f1f1f] whitespace-nowrap\">${m.name}</span>\n        </div>\n      `;\n    }\n\n    function renderDecisions() {\n      const tbody = document.getElementById(\"decisions-body\");\n      const emptyState = document.getElementById(\"empty-state\");\n      const query = document.getElementById(\"search-input\").value.toLowerCase();\n      const statusFilter = document.getElementById(\"status-filter\").value;\n      const ownerFilter = document.getElementById(\"owner-filter\").value;\n\n      const filtered = decisions.filter(d => {\n        const matchesSearch = d.title.toLowerCase().includes(query) || d.details.toLowerCase().includes(query);\n        const matchesStatus = statusFilter === \"all\" || d.status === statusFilter;\n        const matchesOwner = ownerFilter === \"all\" || d.owner === ownerFilter;\n        return matchesSearch && matchesStatus && matchesOwner;\n      });\n\n      filtered.sort((a, b) => new Date(b.date) - new Date(a.date));\n\n      tbody.innerHTML = \"\";\n\n      if (filtered.length === 0) {\n        emptyState.classList.remove(\"hidden\");\n      } else {\n        emptyState.classList.add(\"hidden\");\n        filtered.forEach(d => {\n          const row = document.createElement(\"tr\");\n          row.className = \"hover:bg-[#f0f4f9]/30 transition border-b border-slate-100 last:border-b-0\";\n\n          let statusClass = \"text-slate-600\";\n          if (d.status === \"Approved\") statusClass = \"text-[#0b57d0] font-medium\";\n          else if (d.status === \"Proposed\") statusClass = \"text-slate-700 font-medium\";\n          else if (d.status === \"Deferred\") statusClass = \"text-slate-400\";\n\n          row.innerHTML = `\n            <td class=\"px-4 py-3 text-xs text-slate-500 whitespace-nowrap align-top\">${d.date}</td>\n            <td class=\"px-4 py-3 align-top\">\n              <div class=\"font-medium text-[#1f1f1f] text-xs\">${escapeHtml(d.title)}</div>\n              <div class=\"text-xs text-slate-500 mt-1 max-w-md break-words\">${escapeHtml(d.details)}</div>\n            </td>\n            <td class=\"px-4 py-3 align-top\">\n              ${renderAvatar(d.owner)}\n            </td>\n            <td class=\"px-4 py-3 align-top\">\n              <select \n                onchange=\"updateDecisionStatus('${d.id}', this.value)\" \n                class=\"bg-transparent text-xs outline-none cursor-pointer border-b border-transparent hover:border-slate-300 focus:border-[#0b57d0] pb-0.5 transition ${statusClass}\"\n              >\n                <option class=\"text-slate-700 font-normal\" value=\"Proposed\" ${d.status === 'Proposed' ? 'selected' : ''}>Proposed</option>\n                <option class=\"text-slate-700 font-normal\" value=\"Approved\" ${d.status === 'Approved' ? 'selected' : ''}>Approved</option>\n                <option class=\"text-slate-700 font-normal\" value=\"Deferred\" ${d.status === 'Deferred' ? 'selected' : ''}>Deferred</option>\n              </select>\n            </td>\n            <td class=\"px-4 py-3 align-top text-center\">\n              <button \n                onclick=\"deleteDecision('${d.id}')\" \n                class=\"text-slate-400 hover:text-red-600 transition focus:outline-none p-1\"\n                title=\"Delete Decision\"\n              >\n                <svg class=\"w-3.5 h-3.5 inline\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16\"></path>\n                </svg>\n              </button>\n            </td>\n          `;\n          tbody.appendChild(row);\n        });\n      }\n    }\n\n    async function loadSyncedState() {\n      if (!envId) {\n        // Fallback local storage for preview environment\n        const localData = localStorage.getItem(syncKey);\n        decisions = localData ? JSON.parse(localData) : getDefaultDecisions();\n        renderDecisions();\n        return;\n      }\n      try {\n        const res = await fetch(`/api/sync/${envId}/${syncKey}`);\n        const json = await res.json();\n        if (json.data) {\n          decisions = json.data;\n          renderDecisions();\n        } else {\n          decisions = getDefaultDecisions();\n          renderDecisions();\n        }\n      } catch (err) {\n        console.error(\"Failed to load synced state:\", err);\n      }\n    }\n\n    async function saveSyncedState(newState) {\n      if (!envId) {\n        localStorage.setItem(syncKey, JSON.stringify(newState));\n        return;\n      }\n      try {\n        await fetch(`/api/sync/${envId}/${syncKey}`, {\n          method: \"POST\",\n          headers: { \"Content-Type\": \"application/json\" },\n          body: JSON.stringify({ data: newState })\n        });\n      } catch (err) {\n        console.error(\"Failed to save synced state:\", err);\n      }\n    }\n\n    function updateDecisionStatus(id, newStatus) {\n      const idx = decisions.findIndex(d => d.id === id);\n      if (idx !== -1) {\n        decisions[idx].status = newStatus;\n        saveSyncedState(decisions);\n        renderDecisions();\n      }\n    }\n\n    function deleteDecision(id) {\n      if (confirm(\"Are you sure you want to delete this decision?\")) {\n        decisions = decisions.filter(d => d.id !== id);\n        saveSyncedState(decisions);\n        renderDecisions();\n      }\n    }\n\n    // Set default date to today\n    document.getElementById(\"form-date\").value = new Date().toISOString().split('T')[0];\n\n    // Form Submit\n    document.getElementById(\"decision-form\").addEventListener(\"submit\", function(e) {\n      e.preventDefault();\n      const title = document.getElementById(\"form-title\").value.trim();\n      const details = document.getElementById(\"form-details\").value.trim();\n      const owner = document.getElementById(\"form-owner\").value;\n      const status = document.getElementById(\"form-status\").value;\n      const date = document.getElementById(\"form-date\").value;\n\n      if (!title || !details || !date) return;\n\n      const newDecision = {\n        id: \"dec-\" + Date.now(),\n        title,\n        details,\n        owner,\n        status,\n        date\n      };\n\n      decisions.unshift(newDecision);\n      saveSyncedState(decisions);\n      renderDecisions();\n\n      // Clear input fields\n      document.getElementById(\"form-title\").value = \"\";\n      document.getElementById(\"form-details\").value = \"\";\n      document.getElementById(\"form-date\").value = new Date().toISOString().split('T')[0];\n    });\n\n    // Sync Initialization\n    loadSyncedState();\n    if (envId) {\n      setInterval(loadSyncedState, 2000);\n    }\n  </script>\n</body>\n</html>",
      "title": "Decision & Risk Log"
    },
