    {
      "name": "index.html",
      "type": "code",
      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Client Policy Issues Tracker</title>\n  <!-- Google Sans & Google Sans Text Fonts -->\n  <link href=\"https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&family=Google+Sans+Text:wght@400;500&display=swap\" rel=\"stylesheet\">\n  <!-- Tailwind CSS CDN -->\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script>\n    tailwind.config = {\n      theme: {\n        extend: {\n          fontFamily: {\n            sans: ['\"Google Sans\"', '\"Google Sans Text\"', 'sans-serif'],\n            body: ['\"Google Sans Text\"', 'sans-serif'],\n          },\n        },\n      },\n    }\n  </script>\n  <style>\n    :root {\n      --gemini-rail-icon-gap: 0px;\n      --gemini-side-panel-padding-left: 16px;\n      --gemini-side-panel-padding-right: 16px;\n      --gemini-header-padding-left: 10px;\n      --gemini-header-padding-right: 12px;\n      --gemini-header-elements-gap: 8px;\n    }\n    body {\n      font-family: \"Google Sans Text\", sans-serif;\n      background-color: #ffffff;\n      color: #1f1f1f;\n    }\n    h1, h2, h3, h4, h5, h6, button {\n      font-family: \"Google Sans\", sans-serif;\n    }\n    .no-scrollbar::-webkit-scrollbar {\n      display: none;\n    }\n    .no-scrollbar {\n      -ms-overflow-style: none;\n      scrollbar-width: none;\n    }\n  </style>\n</head>\n<body class=\"bg-white\">\n\n<div class=\"flex h-screen overflow-hidden bg-white\">\n  <!-- Left Side: Issues List & Filter controls -->\n  <div class=\"w-full md:w-[420px] flex flex-col border-r border-slate-200 h-full bg-white select-none\">\n    \n    <!-- Top Filter & Search Controls -->\n    <div class=\"p-4 border-b border-slate-100 space-y-3\">\n      <div class=\"flex items-center justify-between\">\n        <span class=\"text-xs font-semibold text-slate-500 uppercase tracking-wider\">Policy Issue Logs</span>\n        <button id=\"new-issue-btn\" onclick=\"startCreateNewIssue()\" class=\"bg-[#0b57d0] hover:bg-[#0842a0] text-white px-3 py-1.5 rounded text-xs font-medium transition-colors flex items-center space-x-1\">\n          <span>+ New Issue</span>\n        </button>\n      </div>\n\n      <!-- Search Input -->\n      <div class=\"relative\">\n        <input type=\"text\" id=\"search-input\" oninput=\"renderIssuesList()\" placeholder=\"Search client or description...\" class=\"w-full pl-8 pr-3 py-1.5 text-xs bg-[#f0f4f9] rounded border border-transparent focus:bg-white focus:border-[#0b57d0] outline-none transition-all\">\n        <svg class=\"absolute left-2.5 top-2 h-4 w-4 text-slate-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n          <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\"></path>\n        </svg>\n      </div>\n\n      <!-- Compact Select Filters -->\n      <div class=\"grid grid-cols-3 gap-2\">\n        <select id=\"filter-severity\" onchange=\"renderIssuesList()\" class=\"bg-transparent border border-slate-200 rounded px-2 py-1 text-[11px] text-slate-600 outline-none\">\n          <option value=\"\">All Severities</option>\n          <option value=\"Critical\">Critical</option>\n          <option value=\"High\">High</option>\n          <option value=\"Medium\">Medium</option>\n          <option value=\"Low\">Low</option>\n        </select>\n        <select id=\"filter-status\" onchange=\"renderIssuesList()\" class=\"bg-transparent border border-slate-200 rounded px-2 py-1 text-[11px] text-slate-600 outline-none\">\n          <option value=\"\">All Statuses</option>\n          <option value=\"Open\">Open</option>\n          <option value=\"Investigating\">Investigating</option>\n          <option value=\"Mitigation\">Mitigation</option>\n          <option value=\"Resolved\">Resolved</option>\n        </select>\n        <select id=\"filter-client\" onchange=\"renderIssuesList()\" class=\"bg-transparent border border-slate-200 rounded px-2 py-1 text-[11px] text-slate-600 outline-none\">\n          <option value=\"\">All Clients</option>\n        </select>\n      </div>\n    </div>\n\n    <!-- Scrollable Issues List -->\n    <div id=\"issues-list\" class=\"flex-1 overflow-y-auto divide-y divide-slate-100 no-scrollbar\">\n      <!-- Generated Dynamically -->\n    </div>\n  </div>\n\n  <!-- Right Side: Details Pane / Editor Form -->\n  <div id=\"details-pane\" class=\"flex-1 flex flex-col h-full overflow-y-auto bg-white\">\n    <!-- Generated Dynamically -->\n  </div>\n</div>\n\n<script>\n  // Real Workspace Team Members Map\n  const teamMembers = [\n    { name: \"Sakura Okoro\", email: \"sakura@example.com\", initials: \"SO\", color: \"#e8f0fe\", textColor: \"#1967d2\" },\n    { name: \"Malik Harold\", email: \"malik@example.com\", initials: \"MH\", color: \"#fce8e6\", textColor: \"#c5221f\" },\n    { name: \"Adam Lee\", email: \"adam@example.com\", initials: \"AL\", color: \"#e6f4ea\", textColor: \"#137333\" }\n  ];\n\n  // Default initial set of issues synced from drive contexts\n  const defaultIssues = [\n    {\n      id: \"ISSUE-101\",\n      client: \"Aegis AI\",\n      description: \"LLM Jailbreak Escape: Zero-day prompt injection bypass on customer support chatbot returning prohibited toxicity responses.\",\n      source: \"policy_issue_triage_framework.gdoc\",\n      severity: \"High\",\n      status: \"Mitigation\",\n      ownerEmail: \"sakura@example.com\",\n      resolution: \"Implemented initial system-level guardrails. Currently run adversarial testing against updated prompt templates.\",\n      dateReported: \"2026-07-14\"\n    },\n    {\n      id: \"ISSUE-102\",\n      client: \"Veritas Social\",\n      description: \"Harassment Classifier Bypass: Custom Unicode characters allow evasion of primary toxic intent filtering model.\",\n      source: \"cross_client_policy_issues_matrix.csv\",\n      severity: \"Medium\",\n      status: \"Resolved\",\n      ownerEmail: \"malik@example.com\",\n      resolution: \"Retrained neural classifier on Unicode homoglyph datasets. Deployed model patch v2.1 to staging.\",\n      dateReported: \"2026-07-15\"\n    },\n    {\n      id: \"ISSUE-103\",\n      client: \"Nexus Pay\",\n      description: \"Credential Stuffing ATO Spike: Brute-force automated login spikes targeting authentication endpoints.\",\n      source: \"client_policy_issues_tracker.doc\",\n      severity: \"High\",\n      status: \"Investigating\",\n      ownerEmail: \"adam@example.com\",\n      resolution: \"Currently evaluating rate limit rules, blocking high-risk subnets, and implementing emergency step-up MFA.\",\n      dateReported: \"2026-07-12\"\n    },\n    {\n      id: \"ISSUE-104\",\n      client: \"Veritas Social\",\n      description: \"CSAM PhotoDNA Hash Sync Discrepancy: PhotoDNA backend queue integration failing during peak traffic hours.\",\n      source: \"client_policy_issues_deck.gslides\",\n      severity: \"Critical\",\n      status: \"Resolved\",\n      ownerEmail: \"sakura@example.com\",\n      resolution: \"Identified and patched buffer lock in core library handler. Automated recovery is now active.\",\n      dateReported: \"2026-07-13\"\n    },\n    {\n      id: \"ISSUE-105\",\n      client: \"Aegis AI\",\n      description: \"EU DSA Transparency Audit: Discrepancy report detailing gaps in transparency dashboards.\",\n      source: \"cross_client_policy_issues_matrix.csv\",\n      severity: \"Medium\",\n      status: \"Open\",\n      ownerEmail: \"adam@example.com\",\n      resolution: \"\",\n      dateReported: \"2026-07-10\"\n    }\n  ];\n\n  // Application State\n  let issues = [];\n  let selectedIssueId = null;\n\n  // Real-time synchronization state configs\n  const envId = window.__sandboxEnvId;\n  const syncKey = \"client_policy_issues_state_v1\";\n\n  // Escape HTML helper\n  function escapeHTML(str) {\n    if (!str) return '';\n    return str\n      .replace(/&/g, '&amp;')\n      .replace(/</g, '&lt;')\n      .replace(/>/g, '&gt;')\n      .replace(/\"/g, '&quot;')\n      .replace(/'/g, '&#039;');\n  }\n\n  // Get member info safely\n  function getMemberByEmail(email) {\n    return teamMembers.find(m => m.email === email) || {\n      name: email || \"Unassigned\",\n      email: email,\n      initials: email ? email.substring(0, 2).toUpperCase() : \"?\",\n      color: \"#f1f3f4\",\n      textColor: \"#5f6368\"\n    };\n  }\n\n  // Check if form is currently active/focused to avoid jumping cursors on sync\n  function isUserEditing() {\n    const active = document.activeElement;\n    if (!active) return false;\n    return active.tagName === \"INPUT\" || active.tagName === \"TEXTAREA\" || active.tagName === \"SELECT\";\n  }\n\n  // Load state from local or API sync endpoints\n  async function loadState() {\n    if (envId) {\n      try {\n        const res = await fetch(`/api/sync/${envId}/${syncKey}`);\n        const json = await res.json();\n        if (json.data && Array.isArray(json.data)) {\n          applyNewIssuesData(json.data);\n          return;\n        }\n      } catch (err) {\n        console.error(\"Failed to fetch synced state:\", err);\n      }\n    }\n    \n    // Fallback to localStorage\n    const local = localStorage.getItem(syncKey);\n    if (local) {\n      try {\n        applyNewIssuesData(JSON.parse(local));\n      } catch (e) {\n        applyNewIssuesData(defaultIssues);\n      }\n    } else {\n      applyNewIssuesData(defaultIssues);\n    }\n  }\n\n  function applyNewIssuesData(data) {\n    const stringifiedNew = JSON.stringify(data);\n    const stringifiedCurrent = JSON.stringify(issues);\n    \n    if (stringifiedNew !== stringifiedCurrent) {\n      issues = data;\n      updateClientFiltersDropdown();\n      renderIssuesList();\n      \n      // Update details view if not editing\n      if (selectedIssueId && !isUserEditing()) {\n        renderDetailsPane();\n      }\n    }\n  }\n\n  // Save current issues array\n  async function saveState() {\n    localStorage.setItem(syncKey, JSON.stringify(issues));\n    updateClientFiltersDropdown();\n    \n    if (envId) {\n      try {\n        await fetch(`/api/sync/${envId}/${syncKey}`, {\n          method: \"POST\",\n          headers: { \"Content-Type\": \"application/json\" },\n          body: JSON.stringify({ data: issues })\n        });\n      } catch (err) {\n        console.error(\"Failed to save synced state:\", err);\n      }\n    }\n  }\n\n  // Update unique clients dropdown\n  function updateClientFiltersDropdown() {\n    const clientSelect = document.getElementById(\"filter-client\");\n    if (!clientSelect) return;\n    const currentVal = clientSelect.value;\n    \n    const clients = [...new Set(issues.map(item => item.client))].filter(Boolean).sort();\n    \n    let html = `<option value=\"\">All Clients</option>`;\n    clients.forEach(c => {\n      html += `<option value=\"${escapeHTML(c)}\">${escapeHTML(c)}</option>`;\n    });\n    clientSelect.innerHTML = html;\n    clientSelect.value = currentVal;\n  }\n\n  // Render Left Side Lists\n  function renderIssuesList() {\n    const container = document.getElementById(\"issues-list\");\n    if (!container) return;\n\n    const searchVal = document.getElementById(\"search-input\").value.toLowerCase();\n    const filterSev = document.getElementById(\"filter-severity\").value;\n    const filterStat = document.getElementById(\"filter-status\").value;\n    const filterClient = document.getElementById(\"filter-client\").value;\n\n    // Filter Issues list\n    let filtered = issues.filter(issue => {\n      const matchSearch = issue.client.toLowerCase().includes(searchVal) || \n                          issue.description.toLowerCase().includes(searchVal) ||\n                          issue.id.toLowerCase().includes(searchVal);\n      const matchSev = !filterSev || issue.severity === filterSev;\n      const matchStat = !filterStat || issue.status === filterStat;\n      const matchClient = !filterClient || issue.client === filterClient;\n      \n      return matchSearch && matchSev && matchStat && matchClient;\n    });\n\n    // Sort Descending by ID\n    filtered.sort((a, b) => b.id.localeCompare(a.id));\n\n    if (filtered.length === 0) {\n      container.innerHTML = `\n        <div class=\"p-8 text-center text-slate-400 text-xs\">\n          No policy issues found matching filters.\n        </div>\n      `;\n      return;\n    }\n\n    let html = \"\";\n    filtered.forEach(issue => {\n      const member = getMemberByEmail(issue.ownerEmail);\n      const isActive = selectedIssueId === issue.id;\n      \n      const activeClass = isActive \n        ? 'bg-[#e8f0fe] border-l-[3px] border-l-[#0b57d0]' \n        : 'hover:bg-slate-50 border-l-[3px] border-l-transparent';\n      \n      // Severity display tags styling parameters\n      let severityClass = \"text-slate-500\";\n      if (issue.severity === \"Critical\") severityClass = \"text-red-600 font-semibold\";\n      else if (issue.severity === \"High\") severityClass = \"text-orange-600 font-semibold\";\n      else if (issue.severity === \"Medium\") severityClass = \"text-blue-600 font-semibold\";\n\n      let statusClass = \"text-slate-500\";\n      if (issue.status === \"Resolved\") statusClass = \"text-green-600 font-medium\";\n      else if (issue.status === \"Mitigation\") statusClass = \"text-purple-600 font-medium\";\n      else if (issue.status === \"Investigating\") statusClass = \"text-amber-600 font-medium\";\n\n      html += `\n        <div onclick=\"selectIssue('${issue.id}')\" class=\"p-4 cursor-pointer transition-colors ${activeClass} border-b border-slate-100 flex flex-col space-y-1\">\n          <div class=\"flex items-center justify-between\">\n            <span class=\"text-[10px] font-mono text-slate-400 tracking-wider font-semibold\">${issue.id}</span>\n            <span class=\"text-[10px] text-slate-400\">${issue.dateReported}</span>\n          </div>\n          <div class=\"text-sm font-medium text-slate-800\">${escapeHTML(issue.client)}</div>\n          <p class=\"text-xs text-slate-500 line-clamp-2 mt-0.5 leading-relaxed\">${escapeHTML(issue.description)}</p>\n          \n          <div class=\"flex items-center justify-between mt-2 pt-1\">\n            <div class=\"flex space-x-2 text-[11px] items-center\">\n              <span class=\"${severityClass}\">${issue.severity}</span>\n              <span class=\"text-slate-300\">•</span>\n              <span class=\"${statusClass}\">${issue.status}</span>\n            </div>\n            \n            <!-- Custom Initials Avatar -->\n            <div class=\"flex items-center space-x-1\" title=\"${escapeHTML(member.name)}\">\n              <div class=\"w-5 h-5 rounded-full flex items-center justify-center text-[9px] font-bold\" style=\"background-color: ${member.color}; color: ${member.textColor};\">\n                ${member.initials}\n              </div>\n            </div>\n          </div>\n        </div>\n      `;\n    });\n\n    container.innerHTML = html;\n  }\n\n  // Handle row selection\n  function selectIssue(id) {\n    selectedIssueId = id;\n    renderIssuesList();\n    renderDetailsPane();\n  }\n\n  function startCreateNewIssue() {\n    selectedIssueId = \"NEW\";\n    renderIssuesList();\n    renderDetailsPane();\n  }\n\n  // Cancel edit sequence\n  function cancelEdit() {\n    selectedIssueId = null;\n    renderIssuesList();\n    renderDetailsPane();\n  }\n\n  // Render Right Side Details / Editor Pane\n  function renderDetailsPane() {\n    const pane = document.getElementById(\"details-pane\");\n    if (!pane) return;\n\n    if (!selectedIssueId) {\n      pane.innerHTML = `\n        <div class=\"flex-1 flex flex-col items-center justify-center p-8 text-slate-400 text-center h-full select-none\">\n          <svg class=\"w-12 h-12 mb-3 text-slate-300\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z\"></path>\n          </svg>\n          <p class=\"text-sm font-medium text-slate-600\">No issue selected</p>\n          <p class=\"text-xs text-slate-400 mt-1\">Select an issue from the list or create a new issue to view and edit triage logs.</p>\n        </div>\n      `;\n      return;\n    }\n\n    let isNew = selectedIssueId === \"NEW\";\n    let issue = null;\n\n    if (isNew) {\n      // Create fresh blank setup with today's date\n      const today = new Date().toISOString().split('T')[0];\n      issue = {\n        id: \"\",\n        client: \"\",\n        description: \"\",\n        source: \"\",\n        severity: \"High\",\n        status: \"Open\",\n        ownerEmail: \"sakura@example.com\",\n        resolution: \"\",\n        dateReported: today\n      };\n    } else {\n      issue = issues.find(i => i.id === selectedIssueId);\n      if (!issue) {\n        pane.innerHTML = `\n          <div class=\"p-8 text-center text-red-500 text-sm\">\n            Error: Issue data not found or has been deleted by another user.\n          </div>\n        `;\n        return;\n      }\n    }\n\n    // Determine current Workspace metadata\n    const activeWorkspaceName = window.__sandboxWorkspaceName || \"Active Workspace\";\n\n    pane.innerHTML = `\n      <div class=\"p-6 max-w-2xl w-full mx-auto space-y-5\">\n        \n        <!-- Header Info -->\n        <div class=\"flex items-center justify-between border-b border-slate-100 pb-3\">\n          <div>\n            <span class=\"text-[10px] text-slate-400 font-mono tracking-wider font-semibold uppercase\">\n              ${isNew ? 'New Entry Creation' : `Issue: ${issue.id}`}\n            </span>\n            <h2 class=\"text-base font-medium text-slate-800 mt-0.5\">\n              ${isNew ? 'Log Policy Violation Issue' : 'Edit Violation Details'}\n            </h2>\n          </div>\n          \n          <div class=\"flex items-center space-x-2 text-[11px] text-slate-400\">\n            <span class=\"w-2 h-2 rounded-full bg-emerald-500 inline-block\"></span>\n            <span>${activeWorkspaceName}</span>\n          </div>\n        </div>\n\n        <form id=\"issue-form\" class=\"space-y-4\" onsubmit=\"handleFormSubmit(event)\">\n          <input type=\"hidden\" id=\"form-issue-id\" value=\"${issue.id}\">\n          \n          <div class=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n            <!-- Client Name -->\n            <div class=\"flex flex-col space-y-1\">\n              <label for=\"form-client\" class=\"text-xs font-semibold text-slate-600\">Client Platform <span class=\"text-red-500\">*</span></label>\n              <input type=\"text\" id=\"form-client\" required class=\"border border-slate-200 rounded px-3 py-1.5 text-xs focus:border-[#0b57d0] focus:outline-none focus:ring-1 focus:ring-[#0b57d0]\" value=\"${escapeHTML(issue.client)}\" placeholder=\"e.g. Aegis AI\">\n            </div>\n\n            <!-- Source Tool -->\n            <div class=\"flex flex-col space-y-1\">\n              <label for=\"form-source\" class=\"text-xs font-semibold text-slate-600\">Source Tool / Doc</label>\n              <input type=\"text\" id=\"form-source\" class=\"border border-slate-200 rounded px-3 py-1.5 text-xs focus:border-[#0b57d0] focus:outline-none focus:ring-1 focus:ring-[#0b57d0]\" value=\"${escapeHTML(issue.source || '')}\" placeholder=\"e.g. policy_issue_triage_framework.gdoc\">\n            </div>\n          </div>\n\n          <div class=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n            <!-- Severity -->\n            <div class=\"flex flex-col space-y-1\">\n              <label for=\"form-severity\" class=\"text-xs font-semibold text-slate-600\">Severity Level</label>\n              <select id=\"form-severity\" class=\"border border-slate-200 rounded px-3 py-1.5 text-xs bg-white focus:border-[#0b57d0] focus:outline-none\">\n                <option value=\"Critical\" ${issue.severity === 'Critical' ? 'selected' : ''}>Critical</option>\n                <option value=\"High\" ${issue.severity === 'High' ? 'selected' : ''}>High</option>\n                <option value=\"Medium\" ${issue.severity === 'Medium' ? 'selected' : ''}>Medium</option>\n                <option value=\"Low\" ${issue.severity === 'Low' ? 'selected' : ''}>Low</option>\n              </select>\n            </div>\n\n            <!-- Status -->\n            <div class=\"flex flex-col space-y-1\">\n              <label for=\"form-status\" class=\"text-xs font-semibold text-slate-600\">Resolution Status</label>\n              <select id=\"form-status\" class=\"border border-slate-200 rounded px-3 py-1.5 text-xs bg-white focus:border-[#0b57d0] focus:outline-none\">\n                <option value=\"Open\" ${issue.status === 'Open' ? 'selected' : ''}>Open</option>\n                <option value=\"Investigating\" ${issue.status === 'Investigating' ? 'selected' : ''}>Investigating</option>\n                <option value=\"Mitigation\" ${issue.status === 'Mitigation' ? 'selected' : ''}>Mitigation</option>\n                <option value=\"Resolved\" ${issue.status === 'Resolved' ? 'selected' : ''}>Resolved</option>\n              </select>\n            </div>\n\n            <!-- Owner -->\n            <div class=\"flex flex-col space-y-1\">\n              <label for=\"form-owner\" class=\"text-xs font-semibold text-slate-600\">Assigned T&S Lead</label>\n              <select id=\"form-owner\" class=\"border border-slate-200 rounded px-3 py-1.5 text-xs bg-white focus:border-[#0b57d0] focus:outline-none\">\n                ${teamMembers.map(m => `<option value=\"${m.email}\" ${issue.ownerEmail === m.email ? 'selected' : ''}>${m.name} (${m.email})</option>`).join('')}\n              </select>\n            </div>\n          </div>\n\n          <!-- Date -->\n          <div class=\"flex flex-col space-y-1 w-full md:w-1/2\">\n            <label for=\"form-date\" class=\"text-xs font-semibold text-slate-600\">Date Reported</label>\n            <input type=\"date\" id=\"form-date\" required class=\"border border-slate-200 rounded px-3 py-1.5 text-xs focus:border-[#0b57d0] focus:outline-none focus:ring-1 focus:ring-[#0b57d0]\" value=\"${issue.dateReported}\">\n          </div>\n\n          <!-- Issue Description -->\n          <div class=\"flex flex-col space-y-1\">\n            <label for=\"form-description\" class=\"text-xs font-semibold text-slate-600\">Issue Description <span class=\"text-red-500\">*</span></label>\n            <textarea id=\"form-description\" rows=\"3\" required class=\"border border-slate-200 rounded px-3 py-1.5 text-xs focus:border-[#0b57d0] focus:outline-none focus:ring-1 focus:ring-[#0b57d0] resize-none\" placeholder=\"Provide description of jailbreaks, content escapes or policy risks...\">${escapeHTML(issue.description)}</textarea>\n          </div>\n\n          <!-- Resolution Details -->\n          <div class=\"flex flex-col space-y-1\">\n            <label for=\"form-resolution\" class=\"text-xs font-semibold text-slate-600\">Resolution Details</label>\n            <textarea id=\"form-resolution\" rows=\"3\" class=\"border border-slate-200 rounded px-3 py-1.5 text-xs focus:border-[#0b57d0] focus:outline-none focus:ring-1 focus:ring-[#0b57d0] resize-none\" placeholder=\"Remediation steps, safety fine-tuning deployments, or policy update confirmations...\">${escapeHTML(issue.resolution || '')}</textarea>\n          </div>\n\n          <!-- Actions Footer bar -->\n          <div class=\"flex items-center justify-between pt-4 border-t border-slate-100\">\n            <div>\n              ${!isNew ? `\n                <button type=\"button\" onclick=\"deleteIssue('${issue.id}')\" class=\"text-red-600 hover:text-red-800 text-xs font-medium flex items-center space-x-1\">\n                  <svg class=\"w-3.5 h-3.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16\"></path>\n                  </svg>\n                  <span>Delete</span>\n                </button>\n              ` : '<div></div>'}\n            </div>\n\n            <div class=\"flex items-center space-x-2\">\n              <button type=\"button\" onclick=\"cancelEdit()\" class=\"border border-slate-200 hover:bg-slate-50 text-slate-700 px-3.5 py-1.5 rounded text-xs font-medium transition-colors\">\n                Cancel\n              </button>\n              <button type=\"submit\" class=\"bg-[#0b57d0] hover:bg-[#0842a0] text-white px-3.5 py-1.5 rounded text-xs font-medium transition-colors\">\n                ${isNew ? 'Create Issue' : 'Save Changes'}\n              </button>\n            </div>\n          </div>\n        </form>\n      </div>\n    `;\n  }\n\n  // Handle Create or Update operations\n  async function handleFormSubmit(event) {\n    event.preventDefault();\n    \n    const idVal = document.getElementById(\"form-issue-id\").value;\n    const clientVal = document.getElementById(\"form-client\").value.trim();\n    const sourceVal = document.getElementById(\"form-source\").value.trim();\n    const severityVal = document.getElementById(\"form-severity\").value;\n    const statusVal = document.getElementById(\"form-status\").value;\n    const ownerEmailVal = document.getElementById(\"form-owner\").value;\n    const dateVal = document.getElementById(\"form-date\").value;\n    const descriptionVal = document.getElementById(\"form-description\").value.trim();\n    const resolutionVal = document.getElementById(\"form-resolution\").value.trim();\n\n    if (selectedIssueId === \"NEW\") {\n      // Find maximum ID to generate next sequentially\n      let maxNum = 100;\n      issues.forEach(i => {\n        const match = i.id.match(/^ISSUE-(\\d+)$/);\n        if (match) {\n          const num = parseInt(match[1]);\n          if (num > maxNum) maxNum = num;\n        }\n      });\n      const nextId = `ISSUE-${maxNum + 1}`;\n\n      const newIssue = {\n        id: nextId,\n        client: clientVal,\n        source: sourceVal,\n        severity: severityVal,\n        status: statusVal,\n        ownerEmail: ownerEmailVal,\n        dateReported: dateVal,\n        description: descriptionVal,\n        resolution: resolutionVal\n      };\n\n      issues.push(newIssue);\n      selectedIssueId = nextId;\n    } else {\n      const idx = issues.findIndex(i => i.id === idVal);\n      if (idx !== -1) {\n        issues[idx].client = clientVal;\n        issues[idx].source = sourceVal;\n        issues[idx].severity = severityVal;\n        issues[idx].status = statusVal;\n        issues[idx].ownerEmail = ownerEmailVal;\n        issues[idx].dateReported = dateVal;\n        issues[idx].description = descriptionVal;\n        issues[idx].resolution = resolutionVal;\n      }\n    }\n\n    await saveState();\n    renderIssuesList();\n    renderDetailsPane();\n  }\n\n  // Handle Delete operation\n  async function deleteIssue(id) {\n    if (!confirm(`Are you sure you want to delete policy issue ${id}?`)) {\n      return;\n    }\n\n    issues = issues.filter(i => i.id !== id);\n    selectedIssueId = null;\n    \n    await saveState();\n    renderIssuesList();\n    renderDetailsPane();\n  }\n\n  // Initialization\n  async function init() {\n    await loadState();\n    \n    // Auto short poll every 2 seconds for flawless multi-user sync\n    if (envId) {\n      setInterval(loadState, 2000);\n    }\n  }\n\n  window.addEventListener('DOMContentLoaded', init);\n</script>\n</body>\n</html>",
