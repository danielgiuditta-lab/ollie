    {
      "name": "index.html",
      "type": "code",
      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Team Kanban Board</title>\n  <!-- Google Fonts -->\n  <link href=\"https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&family=Google+Sans+Text:wght@400;500&display=swap\" rel=\"stylesheet\">\n  <!-- Tailwind CSS -->\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <style>\n    :root {\n      --gemini-rail-icon-gap: 0px;\n      --gemini-side-panel-padding-left: 16px;\n      --gemini-side-panel-padding-right: 16px;\n      --gemini-header-padding-left: 10px;\n      --gemini-header-padding-right: 12px;\n      --gemini-header-elements-gap: 8px;\n    }\n    body {\n      font-family: 'Google Sans Text', sans-serif;\n      background-color: #ffffff;\n      color: #1f1f1f;\n    }\n    h1, h2, h3, button, select, input {\n      font-family: 'Google Sans', sans-serif;\n    }\n    .column-bg {\n      background-color: #f0f4f9;\n    }\n    .primary-btn {\n      background-color: #0b57d0;\n      color: #ffffff;\n    }\n    .primary-btn:hover {\n      background-color: #0842a0;\n    }\n    .dragging {\n      opacity: 0.4;\n      border-style: dashed !important;\n      border-color: #0b57d0 !important;\n    }\n  </style>\n</head>\n<body class=\"bg-white\">\n\n  <div class=\"max-w-6xl mx-auto p-4 md:p-6 space-y-6\">\n    <!-- Controls Panel: Filter & Quick Add -->\n    <div class=\"flex flex-col md:flex-row md:items-center md:justify-between gap-4 border-b border-slate-100 pb-4\">\n      <!-- Search & Filter -->\n      <div class=\"flex flex-wrap items-center gap-2\">\n        <input type=\"text\" id=\"searchInput\" placeholder=\"Search tasks...\" oninput=\"filterTasks()\" class=\"px-3 py-1.5 text-xs rounded-md border border-slate-200 focus:outline-none focus:border-[#0b57d0] w-48 bg-white\">\n        <select id=\"filterAssignee\" onchange=\"filterTasks()\" class=\"px-2 py-1.5 text-xs rounded-md border border-slate-200 focus:outline-none focus:border-[#0b57d0] bg-white\">\n          <option value=\"\">All Assignees</option>\n          <option value=\"Sakura Okoro\">Sakura Okoro</option>\n          <option value=\"Malik Harold\">Malik Harold</option>\n          <option value=\"Adam Lee\">Adam Lee</option>\n        </select>\n      </div>\n\n      <!-- Quick Add Form -->\n      <form id=\"quickAddForm\" onsubmit=\"addTask(event)\" class=\"flex flex-wrap items-center gap-2\">\n        <input type=\"text\" id=\"newTaskTitle\" placeholder=\"Add a new task...\" required class=\"px-3 py-1.5 text-xs rounded-md border border-slate-200 focus:outline-none focus:border-[#0b57d0] w-48 md:w-64 bg-white\">\n        <select id=\"newTaskAssignee\" class=\"px-2 py-1.5 text-xs rounded-md border border-slate-200 focus:outline-none focus:border-[#0b57d0] bg-white\">\n          <option value=\"Sakura Okoro\">Sakura Okoro</option>\n          <option value=\"Malik Harold\">Malik Harold</option>\n          <option value=\"Adam Lee\">Adam Lee</option>\n        </select>\n        <select id=\"newTaskStatus\" class=\"px-2 py-1.5 text-xs rounded-md border border-slate-200 focus:outline-none focus:border-[#0b57d0] bg-white\">\n          <option value=\"todo\">To Do</option>\n          <option value=\"in-progress\">In Progress</option>\n          <option value=\"done\">Done</option>\n        </select>\n        <button type=\"submit\" class=\"primary-btn text-xs font-medium px-4 py-1.5 rounded-md transition-colors\">Add</button>\n      </form>\n    </div>\n\n    <!-- Board Grid -->\n    <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n      \n      <!-- TO DO -->\n      <div class=\"flex flex-col rounded-lg p-4 column-bg min-h-[500px]\" ondragover=\"allowDrop(event)\" ondrop=\"drop(event, 'todo')\">\n        <div class=\"flex items-center justify-between mb-3 px-1\">\n          <h3 class=\"text-sm font-medium text-slate-700 flex items-center gap-2\">To Do <span id=\"count-todo\" class=\"text-xs bg-slate-200 text-slate-600 px-2 py-0.5 rounded-full\">0</span></h3>\n        </div>\n        <div id=\"col-todo\" class=\"space-y-3 flex-1 overflow-y-auto\"></div>\n      </div>\n\n      <!-- IN PROGRESS -->\n      <div class=\"flex flex-col rounded-lg p-4 column-bg min-h-[500px]\" ondragover=\"allowDrop(event)\" ondrop=\"drop(event, 'in-progress')\">\n        <div class=\"flex items-center justify-between mb-3 px-1\">\n          <h3 class=\"text-sm font-medium text-slate-700 flex items-center gap-2\">In Progress <span id=\"count-in-progress\" class=\"text-xs bg-slate-200 text-slate-600 px-2 py-0.5 rounded-full\">0</span></h3>\n        </div>\n        <div id=\"col-in-progress\" class=\"space-y-3 flex-1 overflow-y-auto\"></div>\n      </div>\n\n      <!-- DONE -->\n      <div class=\"flex flex-col rounded-lg p-4 column-bg min-h-[500px]\" ondragover=\"allowDrop(event)\" ondrop=\"drop(event, 'done')\">\n        <div class=\"flex items-center justify-between mb-3 px-1\">\n          <h3 class=\"text-sm font-medium text-slate-700 flex items-center gap-2\">Done <span id=\"count-done\" class=\"text-xs bg-slate-200 text-slate-600 px-2 py-0.5 rounded-full\">0</span></h3>\n        </div>\n        <div id=\"col-done\" class=\"space-y-3 flex-1 overflow-y-auto\"></div>\n      </div>\n\n    </div>\n  </div>\n\n  <script>\n    const envId = window.__sandboxEnvId;\n    const syncKey = \"team_kanban_board_state\";\n\n    // Standard workspace team members\n    const teamMembers = [\n      { name: \"Sakura Okoro\", email: \"sakura@example.com\", initials: \"SO\", color: \"#0f766e\" },\n      { name: \"Malik Harold\", email: \"malik@example.com\", initials: \"MH\", color: \"#1d4ed8\" },\n      { name: \"Adam Lee\", email: \"adam@example.com\", initials: \"AL\", color: \"#b45309\" }\n    ];\n\n    // Preloaded tasks containing context from the hospital files\n    let tasks = [\n      { id: \"task-1\", title: \"Automate EHR severity tags (ESI level)\", status: \"todo\", assignee: \"Sakura Okoro\", doc: \"patient_inquiry_and_triage_flow.doc\" },\n      { id: \"task-2\", title: \"Monitor triage-to-bed allocation latency\", status: \"in-progress\", assignee: \"Malik Harold\", doc: \"patient_inquiry_and_triage_flow.doc\" },\n      { id: \"task-3\", title: \"Mandate SBAR handoff protocols prior to transfer\", status: \"done\", assignee: \"Adam Lee\", doc: \"patient_inquiry_and_triage_flow.doc\" },\n      { id: \"task-4\", title: \"Build Live Care Journey Tracker framework\", status: \"todo\", assignee: \"Sakura Okoro\", doc: \"patient_experience_h2_roadmap_spec.gdoc\" },\n      { id: \"task-5\", title: \"Incorporate interactive PACU to Ward map transitions\", status: \"in-progress\", assignee: \"Malik Harold\", doc: \"patient_experience_h2_roadmap_spec.gdoc\" },\n      { id: \"task-6\", title: \"Configure patient satisfaction metric SMS triggers\", status: \"done\", assignee: \"Adam Lee\", doc: \"hospital_journey_executive_deck.gslides\" }\n    ];\n\n    let isSaving = false;\n    let draggedId = null;\n\n    // Real-Time Synchronization API Helper\n    async function loadSyncedState() {\n      if (!envId) return;\n      try {\n        const res = await fetch(`/api/sync/${envId}/${syncKey}`);\n        const json = await res.json();\n        if (json.data && !isSaving) {\n          // Avoid active input focus resetting by rendering only when states actually differ\n          if (JSON.stringify(tasks) !== JSON.stringify(json.data)) {\n            tasks = json.data;\n            renderBoard();\n          }\n        }\n      } catch (err) {\n        console.error(\"Failed to load synced state:\", err);\n      }\n    }\n\n    async function saveSyncedState(newState) {\n      if (!envId) return;\n      isSaving = true;\n      try {\n        await fetch(`/api/sync/${envId}/${syncKey}`, {\n          method: \"POST\",\n          headers: { \"Content-Type\": \"application/json\" },\n          body: JSON.stringify({ data: newState })\n        });\n      } catch (err) {\n        console.error(\"Failed to save synced state:\", err);\n      } finally {\n        isSaving = false;\n      }\n    }\n\n    // HTML5 Drag and Drop Handlers\n    function dragStart(e) {\n      draggedId = e.target.id;\n      e.target.classList.add('dragging');\n      e.dataTransfer.setData('text/plain', e.target.id);\n    }\n\n    function dragEnd(e) {\n      e.target.classList.remove('dragging');\n    }\n\n    function allowDrop(e) {\n      e.preventDefault();\n    }\n\n    function drop(e, columnStatus) {\n      e.preventDefault();\n      const id = e.dataTransfer.getData('text/plain') || draggedId;\n      if (id) {\n        updateTaskStatus(id, columnStatus);\n      }\n    }\n\n    // Task Actions\n    function updateTaskStatus(id, newStatus) {\n      tasks = tasks.map(t => t.id === id ? { ...t, status: newStatus } : t);\n      renderBoard();\n      saveSyncedState(tasks);\n    }\n\n    function updateTaskAssignee(id, newAssignee) {\n      tasks = tasks.map(t => t.id === id ? { ...t, assignee: newAssignee } : t);\n      renderBoard();\n      saveSyncedState(tasks);\n    }\n\n    function deleteTask(id) {\n      tasks = tasks.filter(t => t.id !== id);\n      renderBoard();\n      saveSyncedState(tasks);\n    }\n\n    function addTask(e) {\n      e.preventDefault();\n      const titleInput = document.getElementById('newTaskTitle');\n      const assigneeSelect = document.getElementById('newTaskAssignee');\n      const statusSelect = document.getElementById('newTaskStatus');\n\n      if (!titleInput || !titleInput.value.trim()) return;\n\n      const newTask = {\n        id: 'task-' + Date.now(),\n        title: titleInput.value.trim(),\n        status: statusSelect.value,\n        assignee: assigneeSelect.value,\n        doc: '' \n      };\n\n      tasks.push(newTask);\n      titleInput.value = '';\n      \n      renderBoard();\n      saveSyncedState(tasks);\n    }\n\n    function filterTasks() {\n      renderBoard();\n    }\n\n    function escapeHtml(string) {\n      return String(string).replace(/[&<>\"']/g, function (s) {\n        return {\n          '&': '&amp;',\n          '<': '&lt;',\n          '>': '&gt;',\n          '\"': '&quot;',\n          \"'\": '&#39;'\n        }[s];\n      });\n    }\n\n    function renderCard(task) {\n      const member = teamMembers.find(m => m.name === task.assignee) || teamMembers[0];\n      \n      const assigneeOptions = teamMembers.map(m => \n        `<option value=\"${m.name}\" ${m.name === task.assignee ? 'selected' : ''}>${m.name}</option>`\n      ).join('');\n\n      const statusOptions = [\n        { value: 'todo', label: 'To Do' },\n        { value: 'in-progress', label: 'In Progress' },\n        { value: 'done', label: 'Done' }\n      ].map(o => \n        `<option value=\"${o.value}\" ${o.value === task.status ? 'selected' : ''}>${o.label}</option>`\n      ).join('');\n\n      const docLabel = task.doc ? `<div class=\"text-[10px] text-slate-500 font-medium bg-slate-100 rounded px-1.5 py-0.5 mt-1.5 inline-flex items-center gap-1 max-w-full truncate\" title=\"${task.doc}\">📄 ${task.doc}</div>` : '';\n\n      return `\n        <div id=\"${task.id}\" draggable=\"true\" ondragstart=\"dragStart(event)\" ondragend=\"dragEnd(event)\" class=\"bg-white border border-slate-200 rounded-lg p-3 hover:border-slate-300 transition-all cursor-grab active:cursor-grabbing space-y-2\">\n          <div class=\"flex items-start justify-between gap-2\">\n            <span class=\"text-xs font-normal text-slate-900 leading-normal break-words\">${escapeHtml(task.title)}</span>\n            <button onclick=\"deleteTask('${task.id}')\" class=\"text-slate-400 hover:text-red-500 transition-colors\" title=\"Delete task\">\n              <svg class=\"w-3.5 h-3.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16\" /></svg>\n            </button>\n          </div>\n          \n          ${docLabel}\n          \n          <div class=\"pt-2 border-t border-slate-100 flex items-center justify-between gap-2\">\n            <!-- Assignee and Initials Badge -->\n            <div class=\"flex items-center gap-1.5 min-w-0\">\n              <div class=\"w-5 h-5 rounded-full flex items-center justify-center text-white text-[9px] font-bold shrink-0\" style=\"background-color: ${member.color};\" title=\"${member.name}\">\n                ${member.initials}\n              </div>\n              <select onchange=\"updateTaskAssignee('${task.id}', this.value)\" class=\"bg-transparent text-[11px] text-slate-600 focus:outline-none cursor-pointer hover:text-slate-900 font-medium truncate max-w-[85px]\">\n                ${assigneeOptions}\n              </select>\n            </div>\n\n            <!-- Interactive Column Transfer -->\n            <select onchange=\"updateTaskStatus('${task.id}', this.value)\" class=\"bg-transparent text-[11px] text-[#0b57d0] focus:outline-none cursor-pointer hover:text-[#0842a0] font-medium text-right\">\n              ${statusOptions}\n            </select>\n          </div>\n        </div>\n      `;\n    }\n\n    function renderBoard() {\n      const searchTerm = (document.getElementById('searchInput')?.value || '').toLowerCase();\n      const filterAssigneeVal = document.getElementById('filterAssignee')?.value || '';\n\n      const columns = {\n        'todo': document.getElementById('col-todo'),\n        'in-progress': document.getElementById('col-in-progress'),\n        'done': document.getElementById('col-done')\n      };\n\n      const counts = { 'todo': 0, 'in-progress': 0, 'done': 0 };\n\n      // Clear columns\n      Object.values(columns).forEach(col => { if(col) col.innerHTML = ''; });\n\n      tasks.forEach(task => {\n        const matchesSearch = task.title.toLowerCase().includes(searchTerm) || (task.doc && task.doc.toLowerCase().includes(searchTerm));\n        const matchesAssignee = !filterAssigneeVal || task.assignee === filterAssigneeVal;\n\n        if (matchesSearch && matchesAssignee) {\n          if (columns[task.status]) {\n            columns[task.status].insertAdjacentHTML('beforeend', renderCard(task));\n            counts[task.status]++;\n          }\n        }\n      });\n\n      // Update Column Counters\n      Object.keys(counts).forEach(status => {\n        const el = document.getElementById(`count-${status}`);\n        if (el) el.innerText = counts[status];\n      });\n    }\n\n    // Set up Polling Loop and Initial State\n    window.addEventListener('DOMContentLoaded', () => {\n      renderBoard();\n      if (envId) {\n        loadSyncedState();\n        setInterval(loadSyncedState, 2000);\n      }\n    });\n  </script>\n</body>\n</html>",
