{
  "id": "zqhwycq7",
  "envId": "66ff31b9-c2ba-462b-9eec-2f66465dea53",
  "workspaceName": "AI Search Summary",
  "owner": "danielgiuditta@google.com",
  "ownerId": "100789219461204006343",
  "files": [
    {
      "name": "index.html",
      "type": "code",
      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Material 3 Kanban Board</title>\n  \n  <!-- Google Fonts: Plus Jakarta Sans & Material Symbols -->\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20,400,0,0;20,400,1,0&display=swap\" rel=\"stylesheet\">\n  \n  <!-- Tailwind CSS CDN -->\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script>\n    tailwind.config = {\n      theme: {\n        extend: {\n          fontFamily: {\n            sans: ['\"Plus Jakarta Sans\"', 'sans-serif'],\n          },\n          colors: {\n            m3: {\n              primary: '#0b57d0',\n              onPrimary: '#ffffff',\n              primaryContainer: '#d3e3fd',\n              onPrimaryContainer: '#041e49',\n              surface: '#ffffff',\n              surfaceContainerLow: '#f7f9fc',\n              surfaceContainer: '#f0f4f9',\n              surfaceContainerHigh: '#e9eef6',\n              outline: '#74777f',\n              outlineVariant: '#c4c7c5',\n              surfaceVariant: '#e1e2ec',\n              onSurfaceVariant: '#44474f',\n              error: '#ba1a1a',\n            }\n          }\n        }\n      }\n    }\n  </script>\n  \n  <style>\n    /* Thin elegant scrollbars for columns and board */\n    .scrollbar-thin::-webkit-scrollbar {\n      width: 6px;\n      height: 6px;\n    }\n    .scrollbar-thin::-webkit-scrollbar-track {\n      background: transparent;\n    }\n    .scrollbar-thin::-webkit-scrollbar-thumb {\n      background: #c4c7c5;\n      border-radius: 10px;\n    }\n    .scrollbar-thin::-webkit-scrollbar-thumb:hover {\n      background: #74777f;\n    }\n    \n    /* Drag-and-drop animation helpers */\n    .card-dragging {\n      opacity: 0.25;\n      transform: scale(0.97);\n      border: 2px dashed #0b57d0 !important;\n    }\n    .lane-drag-over {\n      background-color: #e3edf9 !important;\n      border-color: #0b57d0 !important;\n    }\n  </style>\n</head>\n<body class=\"bg-m3-surfaceContainerLow text-slate-800 font-sans min-h-screen flex flex-col antialiased select-none\">\n\n  <!-- Header Section -->\n  <header class=\"bg-white border-b border-m3-outlineVariant/30 px-6 py-4 flex flex-col sm:flex-row sm:items-center justify-between gap-4 sticky top-0 z-10 shadow-sm\">\n    <div class=\"flex items-center gap-3\">\n      <div class=\"bg-m3-primaryContainer text-m3-onPrimaryContainer p-2 rounded-xl flex items-center justify-center shadow-sm\">\n        <span class=\"material-symbols-outlined font-semibold\">space_dashboard</span>\n      </div>\n      <div>\n        <h1 class=\"text-base font-bold tracking-tight text-neutral-900\" id=\"workspace-title\">Workspace Board</h1>\n        <div class=\"flex items-center gap-1.5 mt-0.5\">\n          <span class=\"inline-block w-2 h-2 bg-emerald-500 rounded-full animate-pulse\"></span>\n          <span class=\"text-[10px] text-neutral-500 font-bold uppercase tracking-wider\" id=\"sync-status\">Live Synced</span>\n        </div>\n      </div>\n    </div>\n\n    <!-- Actions Toolbar -->\n    <div class=\"flex items-center gap-3 self-end sm:self-auto w-full sm:w-auto justify-end\">\n      <!-- Search Input with Clear Button -->\n      <div class=\"relative w-44 sm:w-64 group\">\n        <span class=\"material-symbols-outlined absolute left-3 top-2.5 text-neutral-400 text-lg\">search</span>\n        <input \n          type=\"text\" \n          id=\"search-input\" \n          placeholder=\"Filter cards...\" \n          class=\"w-full bg-m3-surfaceContainer text-xs pl-9 pr-8 py-2 rounded-full border border-transparent focus:border-m3-primary focus:bg-white outline-none transition-all duration-150\"\n        />\n        <button \n          id=\"clear-search\" \n          onclick=\"clearSearch()\"\n          class=\"absolute right-2.5 top-2.5 text-neutral-400 hover:text-neutral-600 hidden flex items-center justify-center cursor-pointer\"\n        >\n          <span class=\"material-symbols-outlined text-sm\">close</span>\n        </button>\n      </div>\n\n      <!-- Add Task Button -->\n      <button \n        onclick=\"openTaskModal()\" \n        class=\"bg-m3-primary text-white text-xs font-semibold px-4 py-2 rounded-full flex items-center gap-2 hover:bg-blue-700 active:scale-95 transition-all cursor-pointer min-h-[36px]\"\n      >\n        <span class=\"material-symbols-outlined text-base\">add</span>\n        <span>Add Task</span>\n      </button>\n    </div>\n  </header>\n\n  <!-- Kanban Board Columns Grid -->\n  <main class=\"flex-1 overflow-x-auto flex gap-4 p-6 items-start h-[calc(100vh-80px)] scrollbar-thin\" id=\"kanban-lanes-container\">\n    <!-- Lanes rendered dynamically -->\n  </main>\n\n  <!-- Edit/Create Task Modal -->\n  <div id=\"task-modal\" class=\"fixed inset-0 bg-neutral-950/40 backdrop-blur-sm flex items-center justify-center p-4 z-50 hidden opacity-0 transition-opacity duration-200\">\n    <div class=\"bg-white rounded-2xl max-w-md w-full p-6 shadow-xl border border-neutral-100 transform scale-95 transition-transform duration-200 flex flex-col gap-4 max-h-[90vh] overflow-y-auto scrollbar-thin\">\n      <div class=\"flex items-center justify-between\">\n        <h3 id=\"modal-title\" class=\"text-base font-bold text-neutral-900 tracking-tight\">Create Task</h3>\n        <button onclick=\"closeTaskModal()\" class=\"text-neutral-400 hover:text-neutral-600 p-1 rounded-full hover:bg-neutral-100 cursor-pointer flex items-center justify-center\">\n          <span class=\"material-symbols-outlined text-lg\">close</span>\n        </button>\n      </div>\n\n      <form id=\"task-form\" onsubmit=\"handleFormSubmit(event)\" class=\"flex flex-col gap-4\">\n        <input type=\"hidden\" id=\"task-id\" />\n\n        <!-- Title -->\n        <div class=\"flex flex-col gap-1\">\n          <label for=\"modal-task-title\" class=\"text-[11px] font-bold text-neutral-500 uppercase tracking-wider\">Task Title</label>\n          <input \n            type=\"text\" \n            id=\"modal-task-title\" \n            required \n            placeholder=\"What needs to be done?\" \n            class=\"w-full bg-m3-surfaceContainer text-xs px-3.5 py-2.5 rounded-lg border border-transparent focus:border-m3-primary focus:bg-white outline-none transition-all\"\n          />\n        </div>\n\n        <div class=\"grid grid-cols-2 gap-3\">\n          <!-- Lane -->\n          <div class=\"flex flex-col gap-1\">\n            <label for=\"modal-task-lane\" class=\"text-[11px] font-bold text-neutral-500 uppercase tracking-wider\">Status / Column</label>\n            <select \n              id=\"modal-task-lane\" \n              class=\"w-full bg-m3-surfaceContainer text-xs px-3 py-2.5 rounded-lg border border-transparent focus:border-m3-primary focus:bg-white outline-none cursor-pointer transition-all\"\n            >\n              <option value=\"todo\">To Do</option>\n              <option value=\"in-progress\">In Progress</option>\n              <option value=\"done\">Done</option>\n            </select>\n          </div>\n\n          <!-- Priority -->\n          <div class=\"flex flex-col gap-1\">\n            <label class=\"text-[11px] font-bold text-neutral-500 uppercase tracking-wider\">Priority</label>\n            <div class=\"flex gap-1.5\">\n              <label class=\"flex-1 cursor-pointer\">\n                <input type=\"radio\" name=\"modal-priority\" value=\"High\" class=\"sr-only peer\" checked>\n                <div class=\"text-center text-[10px] font-bold py-2 rounded-lg border border-neutral-200 bg-white text-neutral-600 peer-checked:bg-red-50 peer-checked:border-red-300 peer-checked:text-red-700 transition-all\">\n                  High\n                </div>\n              </label>\n              <label class=\"flex-1 cursor-pointer\">\n                <input type=\"radio\" name=\"modal-priority\" value=\"Medium\" class=\"sr-only peer\">\n                <div class=\"text-center text-[10px] font-bold py-2 rounded-lg border border-neutral-200 bg-white text-neutral-600 peer-checked:bg-amber-50 peer-checked:border-amber-300 peer-checked:text-amber-700 transition-all\">\n                  Med\n                </div>\n              </label>\n              <label class=\"flex-1 cursor-pointer\">\n                <input type=\"radio\" name=\"modal-priority\" value=\"Low\" class=\"sr-only peer\">\n                <div class=\"text-center text-[10px] font-bold py-2 rounded-lg border border-neutral-200 bg-white text-neutral-600 peer-checked:bg-emerald-50 peer-checked:border-emerald-300 peer-checked:text-emerald-700 transition-all\">\n                  Low\n                </div>\n              </label>\n            </div>\n          </div>\n        </div>\n\n        <!-- Description -->\n        <div class=\"flex flex-col gap-1\">\n          <label for=\"modal-task-desc\" class=\"text-[11px] font-bold text-neutral-500 uppercase tracking-wider\">Description</label>\n          <textarea \n            id=\"modal-task-desc\" \n            rows=\"2\" \n            placeholder=\"Add quick details...\" \n            class=\"w-full bg-m3-surfaceContainer text-xs px-3.5 py-2 rounded-lg border border-transparent focus:border-m3-primary focus:bg-white outline-none transition-all resize-none\"\n          ></textarea>\n        </div>\n\n        <!-- Subtasks Creator Section -->\n        <div class=\"flex flex-col gap-2 bg-neutral-50 p-3 rounded-xl border border-neutral-200/50\">\n          <label class=\"text-[11px] font-bold text-neutral-500 uppercase tracking-wider\">Subtasks Checklist</label>\n          \n          <div class=\"flex gap-2\">\n            <input \n              type=\"text\" \n              id=\"modal-subtask-input\" \n              placeholder=\"Add checklist item...\" \n              class=\"flex-1 bg-white text-xs px-3 py-2 rounded-lg border border-neutral-200 focus:border-m3-primary outline-none transition-all\"\n            />\n            <button \n              type=\"button\" \n              onclick=\"handleAddSubtaskFromModal()\"\n              class=\"bg-m3-primaryContainer text-m3-onPrimaryContainer hover:bg-blue-100 text-xs font-bold px-3 py-2 rounded-lg transition-all\"\n            >\n              Add\n            </button>\n          </div>\n\n          <!-- Dynamic List of Subtasks -->\n          <ul id=\"modal-subtasks-list\" class=\"flex flex-col gap-1.5 mt-1 max-h-36 overflow-y-auto scrollbar-thin\">\n            <!-- Rendered dynamically -->\n          </ul>\n        </div>\n\n        <!-- Form Actions -->\n        <div class=\"flex items-center justify-end gap-2 mt-2 pt-3 border-t border-neutral-100\">\n          <button \n            type=\"button\" \n            onclick=\"closeTaskModal()\" \n            class=\"px-4 py-2 text-xs font-semibold text-neutral-500 hover:text-neutral-700 rounded-full hover:bg-neutral-100 transition-all cursor-pointer\"\n          >\n            Cancel\n          </button>\n          <button \n            type=\"submit\" \n            class=\"px-5 py-2 bg-m3-primary text-white text-xs font-semibold rounded-full hover:bg-blue-700 active:scale-95 transition-all cursor-pointer shadow\"\n          >\n            Save Task\n          </button>\n        </div>\n      </form>\n    </div>\n  </div>\n\n  <!-- Toast Notification System -->\n  <div id=\"toast\" class=\"fixed bottom-6 right-6 bg-slate-900 text-white text-xs px-4 py-2.5 rounded-lg shadow-lg flex items-center gap-2 transform translate-y-20 opacity-0 transition-all duration-250 z-50 pointer-events-none\">\n    <span class=\"material-symbols-outlined text-emerald-400 text-lg\" id=\"toast-icon\">check_circle</span>\n    <span id=\"toast-message\">Success</span>\n  </div>\n\n  <!-- App Script with Synchronization -->\n  <script>\n    const envId = window.__sandboxEnvId;\n    const workspaceName = window.__sandboxWorkspaceName;\n    const syncKey = \"simple_kanban_state\"; \n\n    if (workspaceName) {\n      document.getElementById('workspace-title').innerText = `${workspaceName} Kanban`;\n    }\n\n    // High fidelity default state with subtasks\n    let state = {\n      cards: [\n        { \n          id: \"card-1\", \n          title: \"✨ Try dragging cards\", \n          lane: \"todo\", \n          priority: \"High\", \n          description: \"Move cards between columns to organize flow.\",\n          subtasks: [\n            { id: \"sub-1-1\", title: \"Drag this card to In Progress\", completed: false },\n            { id: \"sub-1-2\", title: \"Try quick add text at column bottom\", completed: false }\n          ],\n          expanded: true\n        },\n        { \n          id: \"card-2\", \n          title: \"Setup beautiful Material 3 theme\", \n          lane: \"in-progress\", \n          priority: \"Medium\", \n          description: \"Apply responsive grid, nice rounded corners, and soft color roles.\",\n          subtasks: [\n            { id: \"sub-2-1\", title: \"Tailwind config setup\", completed: true },\n            { id: \"sub-2-2\", title: \"Verify touch target dimensions\", completed: false }\n          ],\n          expanded: true\n        },\n        { \n          id: \"card-3\", \n          title: \"Verify real-time multiplayer synchronization\", \n          lane: \"done\", \n          priority: \"Low\", \n          description: \"Workspace operations synchronize seamlessly instantly.\",\n          subtasks: [\n            { id: \"sub-3-1\", title: \"Connect synchronize API hook\", completed: true }\n          ],\n          expanded: false\n        }\n      ],\n      lanes: [\n        { id: \"todo\", title: \"To Do\", icon: \"arrow_forward\" },\n        { id: \"in-progress\", title: \"In Progress\", icon: \"sync\" },\n        { id: \"done\", title: \"Done\", icon: \"check_circle\" }\n      ]\n    };\n\n    let searchQuery = '';\n    let tempModalSubtasks = []; // Holds items during active task creation/edit\n\n    // Load State from sync backend or localStorage fallback\n    async function loadSyncedState() {\n      if (!envId) {\n        const localData = localStorage.getItem(syncKey);\n        if (localData) {\n          const parsed = JSON.parse(localData);\n          if (parsed && parsed.cards) {\n            state = parsed;\n            renderBoard();\n          }\n        }\n        return;\n      }\n      try {\n        const res = await fetch(`/api/sync/${envId}/${syncKey}`);\n        const json = await res.json();\n        if (json && json.data) {\n          if (JSON.stringify(state) !== JSON.stringify(json.data)) {\n            state = json.data;\n            renderBoard();\n          }\n        }\n      } catch (err) {\n        console.error(\"Failed to load state:\", err);\n      }\n    }\n\n    // Save State\n    async function saveSyncedState(newState) {\n      state = newState;\n      renderBoard();\n      localStorage.setItem(syncKey, JSON.stringify(newState));\n\n      if (!envId) return;\n      try {\n        await fetch(`/api/sync/${envId}/${syncKey}`, {\n          method: \"POST\",\n          headers: { \"Content-Type\": \"application/json\" },\n          body: JSON.stringify({ data: newState })\n        });\n      } catch (err) {\n        console.error(\"Failed to save state:\", err);\n      }\n    }\n\n    if (envId) {\n      loadSyncedState();\n      setInterval(loadSyncedState, 2000);\n    } else {\n      loadSyncedState();\n    }\n\n    // Search Trigger\n    const searchInput = document.getElementById('search-input');\n    const clearBtn = document.getElementById('clear-search');\n    \n    searchInput.addEventListener('input', (e) => {\n      searchQuery = e.target.value.toLowerCase();\n      if (searchQuery) {\n        clearBtn.classList.remove('hidden');\n      } else {\n        clearBtn.classList.add('hidden');\n      }\n      renderBoard();\n    });\n\n    function clearSearch() {\n      searchInput.value = '';\n      searchQuery = '';\n      clearBtn.classList.add('hidden');\n      renderBoard();\n    }\n\n    // Toast Notification Controller\n    function showToast(message, isAlert = false) {\n      const toast = document.getElementById('toast');\n      const toastMsg = document.getElementById('toast-message');\n      const toastIcon = document.getElementById('toast-icon');\n\n      toastMsg.innerText = message;\n      if (isAlert) {\n        toastIcon.innerText = 'delete_sweep';\n        toastIcon.className = \"material-symbols-outlined text-red-400 text-lg\";\n      } else {\n        toastIcon.innerText = 'check_circle';\n        toastIcon.className = \"material-symbols-outlined text-emerald-400 text-lg\";\n      }\n\n      toast.className = \"fixed bottom-6 right-6 bg-slate-900 text-white text-xs px-4 py-2.5 rounded-lg shadow-lg flex items-center gap-2 transform translate-y-0 opacity-100 transition-all duration-250 z-50 pointer-events-none\";\n      setTimeout(() => {\n        toast.className = \"fixed bottom-6 right-6 bg-slate-900 text-white text-xs px-4 py-2.5 rounded-lg shadow-lg flex items-center gap-2 transform translate-y-20 opacity-0 transition-all duration-250 z-50 pointer-events-none\";\n      }, 2500);\n    }\n\n    // Render Board\n    function renderBoard() {\n      const container = document.getElementById('kanban-lanes-container');\n      container.innerHTML = '';\n\n      state.lanes.forEach(lane => {\n        let laneCards = state.cards.filter(card => card.lane === lane.id);\n\n        if (searchQuery) {\n          laneCards = laneCards.filter(card => \n            card.title.toLowerCase().includes(searchQuery) || \n            (card.description && card.description.toLowerCase().includes(searchQuery))\n          );\n        }\n\n        const laneEl = document.createElement('div');\n        laneEl.className = \"w-80 min-w-[300px] flex-shrink-0 flex flex-col bg-m3-surfaceContainer rounded-2xl border border-neutral-200/50 p-3.5 h-full max-h-full transition-all\";\n        laneEl.id = `lane-${lane.id}`;\n\n        laneEl.addEventListener('dragover', (e) => {\n          e.preventDefault();\n          laneEl.classList.add('lane-drag-over');\n        });\n        laneEl.addEventListener('dragleave', () => {\n          laneEl.classList.remove('lane-drag-over');\n        });\n        laneEl.addEventListener('drop', (e) => {\n          e.preventDefault();\n          laneEl.classList.remove('lane-drag-over');\n          const cardId = e.dataTransfer.getData('text/plain');\n          if (cardId) moveCardToLane(cardId, lane.id);\n        });\n\n        const headerHtml = `\n          <div class=\"flex items-center justify-between px-1 mb-3 shrink-0\">\n            <div class=\"flex items-center gap-2\">\n              <span class=\"text-xs font-bold text-neutral-800 tracking-wider uppercase\">${lane.title}</span>\n              <span class=\"text-[10px] font-bold bg-neutral-200 text-neutral-700 px-2 py-0.5 rounded-full\">${laneCards.length}</span>\n            </div>\n            <button onclick=\"openTaskModal(null, '${lane.id}')\" class=\"text-neutral-400 hover:text-m3-primary p-1 rounded-full hover:bg-neutral-200/60 cursor-pointer flex items-center justify-center\">\n              <span class=\"material-symbols-outlined text-lg\">add</span>\n            </button>\n          </div>\n        `;\n\n        const cardsListContainer = document.createElement('div');\n        cardsListContainer.className = \"flex-1 overflow-y-auto flex flex-col gap-2.5 pr-1 scrollbar-thin\";\n\n        if (laneCards.length === 0) {\n          cardsListContainer.innerHTML = `\n            <div class=\"flex-1 flex flex-col items-center justify-center py-10 text-center border border-dashed border-neutral-200/60 rounded-xl bg-white/40\">\n              <p class=\"text-[10px] font-bold text-neutral-400 uppercase tracking-wide\">Empty Column</p>\n            </div>\n          `;\n        } else {\n          laneCards.forEach(card => {\n            const cardEl = document.createElement('div');\n            cardEl.className = \"bg-white p-3.5 rounded-xl border border-neutral-200/60 shadow-sm hover:shadow-md hover:border-m3-primary/30 transition-all duration-150 cursor-grab active:cursor-grabbing relative flex flex-col gap-2 group\";\n            cardEl.id = `card-${card.id}`;\n            cardEl.draggable = true;\n\n            // Priority Left Border color-coding\n            let borderClass = \"border-l-4 border-l-slate-200\";\n            let priorityBadgeColor = \"bg-neutral-100 text-neutral-600\";\n            if (card.priority === 'High') {\n              borderClass = \"border-l-4 border-l-red-500\";\n              priorityBadgeColor = \"bg-red-50 text-red-600\";\n            } else if (card.priority === 'Medium') {\n              borderClass = \"border-l-4 border-l-amber-500\";\n              priorityBadgeColor = \"bg-amber-50 text-amber-600\";\n            } else if (card.priority === 'Low') {\n              borderClass = \"border-l-4 border-l-emerald-500\";\n              priorityBadgeColor = \"bg-emerald-50 text-emerald-600\";\n            }\n            cardEl.className += ` ${borderClass}`;\n\n            // Calculate Subtask Progress\n            const subtasks = card.subtasks || [];\n            const completedCount = subtasks.filter(s => s.completed).length;\n            const totalCount = subtasks.length;\n            const progressPercent = totalCount > 0 ? (completedCount / totalCount) * 100 : 0;\n\n            let subtaskHtml = '';\n            if (totalCount > 0) {\n              const isExpanded = card.expanded !== false;\n              subtaskHtml = `\n                <div class=\"mt-2 pt-2 border-t border-neutral-100 flex flex-col gap-1.5\" onclick=\"event.stopPropagation()\">\n                  <!-- Progress Bar and Toggle button -->\n                  <div class=\"flex items-center justify-between text-[10px] text-neutral-500 font-bold uppercase tracking-wide\">\n                    <button onclick=\"toggleCardChecklistExpanded('${card.id}')\" class=\"flex items-center gap-1 hover:text-neutral-800 transition-colors\">\n                      <span class=\"material-symbols-outlined text-xs transform transition-transform duration-150 ${isExpanded ? 'rotate-90' : ''}\">chevron_right</span>\n                      <span>Checklist (${completedCount}/${totalCount})</span>\n                    </button>\n                    <span>${Math.round(progressPercent)}%</span>\n                  </div>\n                  \n                  <div class=\"w-full bg-neutral-100 h-1 rounded-full overflow-hidden\">\n                    <div class=\"bg-m3-primary h-full rounded-full transition-all duration-300\" style=\"width: ${progressPercent}%\"></div>\n                  </div>\n\n                  <!-- Expanded subtask list -->\n                  <div class=\"flex flex-col gap-1 mt-1 transition-all ${isExpanded ? 'block' : 'hidden'}\">\n                    ${subtasks.map(sub => `\n                      <label class=\"flex items-center gap-2 cursor-pointer py-0.5 hover:bg-neutral-50 rounded px-1\">\n                        <input \n                          type=\"checkbox\" \n                          ${sub.completed ? 'checked' : ''} \n                          onclick=\"toggleSubtaskStatus('${card.id}', '${sub.id}')\"\n                          class=\"w-3.5 h-3.5 rounded text-m3-primary border-neutral-300 focus:ring-0 cursor-pointer\"\n                        />\n                        <span class=\"text-[11px] select-none text-neutral-600 leading-tight ${sub.completed ? 'line-through text-neutral-400' : ''}\">${escapeHtml(sub.title)}</span>\n                      </label>\n                    `).join('')}\n                  </div>\n                </div>\n              `;\n            }\n\n            cardEl.innerHTML = `\n              <div class=\"flex items-center justify-between select-none\">\n                <span class=\"px-2 py-0.5 text-[9px] font-bold tracking-wider rounded uppercase ${priorityBadgeColor}\">${card.priority}</span>\n                <div class=\"flex gap-0.5 opacity-0 group-hover:opacity-100 transition-opacity\">\n                  <button onclick=\"event.stopPropagation(); editTask('${card.id}')\" class=\"text-neutral-400 hover:text-neutral-700 p-1 rounded hover:bg-neutral-100 cursor-pointer flex items-center justify-center\">\n                    <span class=\"material-symbols-outlined text-[16px]\">edit</span>\n                  </button>\n                  <button onclick=\"event.stopPropagation(); deleteTask('${card.id}')\" class=\"text-neutral-400 hover:text-red-500 p-1 rounded hover:bg-neutral-100 cursor-pointer flex items-center justify-center\">\n                    <span class=\"material-symbols-outlined text-[16px]\">delete</span>\n                  </button>\n                </div>\n              </div>\n              <h4 class=\"text-xs font-bold text-neutral-800 leading-snug\">${escapeHtml(card.title)}</h4>\n              ${card.description ? `<p class=\"text-[11px] text-neutral-500 line-clamp-2 leading-relaxed mt-0.5\">${escapeHtml(card.description)}</p>` : ''}\n              ${subtaskHtml}\n            `;\n\n            // Drag operations\n            cardEl.addEventListener('dragstart', (e) => {\n              e.dataTransfer.setData('text/plain', card.id);\n              e.dataTransfer.effectAllowed = 'move';\n              setTimeout(() => cardEl.classList.add('card-dragging'), 0);\n            });\n\n            cardEl.addEventListener('dragend', () => {\n              cardEl.classList.remove('card-dragging');\n            });\n\n            cardEl.addEventListener('dblclick', () => editTask(card.id));\n\n            cardsListContainer.appendChild(cardEl);\n          });\n        }\n\n        // Add Quick Input at bottom of the column\n        const quickAddContainer = document.createElement('div');\n        quickAddContainer.className = \"mt-3 shrink-0\";\n        quickAddContainer.innerHTML = `\n          <div id=\"quick-add-btn-box-${lane.id}\">\n            <button \n              onclick=\"showQuickAddInput('${lane.id}')\" \n              class=\"w-full py-1.5 px-2.5 rounded-lg text-[11px] font-bold text-neutral-500 hover:text-neutral-800 hover:bg-neutral-200/50 flex items-center justify-center gap-1 transition-all cursor-pointer\"\n            >\n              <span class=\"material-symbols-outlined text-sm font-bold\">add</span>\n              <span>Quick Add Task</span>\n            </button>\n          </div>\n          <div id=\"quick-add-input-box-${lane.id}\" class=\"hidden\">\n            <input \n              type=\"text\" \n              id=\"quick-add-input-${lane.id}\" \n              placeholder=\"What needs doing? (Press Enter)\" \n              onkeydown=\"handleQuickAddKeydown(event, '${lane.id}')\"\n              onblur=\"hideQuickAddInput('${lane.id}')\"\n              class=\"w-full bg-white text-xs px-3 py-2 rounded-lg border border-neutral-300 focus:border-m3-primary outline-none shadow-sm transition-all\"\n            />\n          </div>\n        `;\n\n        laneEl.innerHTML = headerHtml;\n        laneEl.appendChild(cardsListContainer);\n        laneEl.appendChild(quickAddContainer);\n        container.appendChild(laneEl);\n      });\n    }\n\n    function escapeHtml(text) {\n      if (!text) return '';\n      const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '\"': '&quot;', \"'\": '&#039;' };\n      return text.replace(/[&<>\"']/g, m => map[m]);\n    }\n\n    // Quick Add Handling\n    function showQuickAddInput(laneId) {\n      document.getElementById(`quick-add-btn-box-${laneId}`).classList.add('hidden');\n      const box = document.getElementById(`quick-add-input-box-${laneId}`);\n      box.classList.remove('hidden');\n      const input = document.getElementById(`quick-add-input-${laneId}`);\n      input.focus();\n    }\n\n    function hideQuickAddInput(laneId) {\n      // Small timeout to allow Enter click without immediate blur cancellation\n      setTimeout(() => {\n        const input = document.getElementById(`quick-add-input-${laneId}`);\n        if (input) input.value = '';\n        const btnBox = document.getElementById(`quick-add-btn-box-${laneId}`);\n        const inputBox = document.getElementById(`quick-add-input-box-${laneId}`);\n        if (btnBox) btnBox.classList.remove('hidden');\n        if (inputBox) inputBox.classList.add('hidden');\n      }, 200);\n    }\n\n    function handleQuickAddKeydown(e, laneId) {\n      if (e.key === 'Enter') {\n        const val = e.target.value.trim();\n        if (val) {\n          const newCard = {\n            id: `card-${Date.now()}`,\n            title: val,\n            lane: laneId,\n            priority: 'Medium',\n            description: '',\n            subtasks: [],\n            expanded: true\n          };\n          const updatedCards = [...state.cards, newCard];\n          saveSyncedState({ ...state, cards: updatedCards });\n          showToast(\"Task quick-added\");\n        }\n        hideQuickAddInput(laneId);\n      } else if (e.key === 'Escape') {\n        hideQuickAddInput(laneId);\n      }\n    }\n\n    // Move card logic\n    function moveCardToLane(cardId, targetLaneId) {\n      const card = state.cards.find(c => c.id === cardId);\n      if (card && card.lane !== targetLaneId) {\n        card.lane = targetLaneId;\n        saveSyncedState(state);\n        const lane = state.lanes.find(l => l.id === targetLaneId);\n        showToast(`Moved to ${lane ? lane.title : targetLaneId}`);\n      }\n    }\n\n    // Toggle checklist expand/collapse on board view\n    function toggleCardChecklistExpanded(cardId) {\n      const updatedCards = state.cards.map(c => {\n        if (c.id === cardId) {\n          return { ...c, expanded: c.expanded === false ? true : false };\n        }\n        return c;\n      });\n      saveSyncedState({ ...state, cards: updatedCards });\n    }\n\n    // Toggle subtask status live on board\n    function toggleSubtaskStatus(cardId, subtaskId) {\n      const updatedCards = state.cards.map(c => {\n        if (c.id === cardId) {\n          const updatedSubtasks = c.subtasks.map(s => {\n            if (s.id === subtaskId) {\n              return { ...s, completed: !s.completed };\n            }\n            return s;\n          });\n          return { ...c, subtasks: updatedSubtasks };\n        }\n        return c;\n      });\n      saveSyncedState({ ...state, cards: updatedCards });\n    }\n\n    // Delete Card Task\n    function deleteTask(cardId) {\n      if (confirm(\"Are you sure you want to delete this task?\")) {\n        const filtered = state.cards.filter(c => c.id !== cardId);\n        saveSyncedState({ ...state, cards: filtered });\n        showToast(\"Task deleted\", true);\n      }\n    }\n\n    // Edit Task details inside full Modal\n    function editTask(cardId) {\n      const card = state.cards.find(c => c.id === cardId);\n      if (!card) return;\n\n      document.getElementById('modal-title').innerText = \"Edit Task\";\n      document.getElementById('task-id').value = card.id;\n      document.getElementById('modal-task-title').value = card.title;\n      document.getElementById('modal-task-lane').value = card.lane;\n      document.getElementById('modal-task-desc').value = card.description || '';\n\n      const priorityRadios = document.getElementsByName('modal-priority');\n      priorityRadios.forEach(radio => {\n        if (radio.value === card.priority) radio.checked = true;\n      });\n\n      tempModalSubtasks = card.subtasks ? JSON.parse(JSON.stringify(card.subtasks)) : [];\n      renderModalSubtasks();\n      openTaskModalDirect();\n    }\n\n    // Open Modal flow\n    function openTaskModal(e, defaultLaneId = 'todo') {\n      document.getElementById('modal-title').innerText = \"Create Task\";\n      document.getElementById('task-id').value = '';\n      document.getElementById('task-form').reset();\n      document.getElementById('modal-task-lane').value = defaultLaneId;\n      tempModalSubtasks = [];\n      renderModalSubtasks();\n      openTaskModalDirect();\n    }\n\n    function openTaskModalDirect() {\n      const modal = document.getElementById('task-modal');\n      modal.classList.remove('hidden');\n      setTimeout(() => {\n        modal.classList.add('opacity-100');\n        modal.firstElementChild.classList.remove('scale-95');\n        modal.firstElementChild.classList.add('scale-100');\n      }, 50);\n    }\n\n    function closeTaskModal() {\n      const modal = document.getElementById('task-modal');\n      modal.classList.remove('opacity-100');\n      modal.firstElementChild.classList.remove('scale-100');\n      modal.firstElementChild.classList.add('scale-95');\n      setTimeout(() => modal.classList.add('hidden'), 200);\n    }\n\n    // Dynamic Modal subtask builder\n    function handleAddSubtaskFromModal() {\n      const input = document.getElementById('modal-subtask-input');\n      const val = input.value.trim();\n      if (val) {\n        tempModalSubtasks.push({\n          id: `sub-${Date.now()}`,\n          title: val,\n          completed: false\n        });\n        input.value = '';\n        renderModalSubtasks();\n      }\n    }\n\n    function removeSubtaskFromModal(subtaskId) {\n      tempModalSubtasks = tempModalSubtasks.filter(s => s.id !== subtaskId);\n      renderModalSubtasks();\n    }\n\n    function renderModalSubtasks() {\n      const container = document.getElementById('modal-subtasks-list');\n      container.innerHTML = '';\n      \n      if (tempModalSubtasks.length === 0) {\n        container.innerHTML = `<li class=\"text-[10px] text-neutral-400 italic\">No checklist items yet</li>`;\n        return;\n      }\n\n      tempModalSubtasks.forEach(sub => {\n        const li = document.createElement('li');\n        li.className = \"flex items-center justify-between bg-white px-2.5 py-1.5 rounded-lg border border-neutral-200 text-xs\";\n        li.innerHTML = `\n          <div class=\"flex items-center gap-2\">\n            <span class=\"material-symbols-outlined text-[16px] text-neutral-400\">check_box_outline_blank</span>\n            <span class=\"text-neutral-700 font-medium\">${escapeHtml(sub.title)}</span>\n          </div>\n          <button type=\"button\" onclick=\"removeSubtaskFromModal('${sub.id}')\" class=\"text-neutral-400 hover:text-red-500 cursor-pointer flex items-center justify-center\">\n            <span class=\"material-symbols-outlined text-sm\">delete</span>\n          </button>\n        `;\n        container.appendChild(li);\n      });\n    }\n\n    // Handle save and update inside modal form\n    function handleFormSubmit(e) {\n      e.preventDefault();\n      \n      const cardId = document.getElementById('task-id').value;\n      const title = document.getElementById('modal-task-title').value;\n      const lane = document.getElementById('modal-task-lane').value;\n      const description = document.getElementById('modal-task-desc').value;\n      \n      let priority = 'High';\n      const priorityRadios = document.getElementsByName('modal-priority');\n      priorityRadios.forEach(radio => {\n        if (radio.checked) priority = radio.value;\n      });\n\n      let updatedCards = [...state.cards];\n\n      if (cardId) {\n        updatedCards = updatedCards.map(c => {\n          if (c.id === cardId) {\n            return { \n              ...c, \n              title, \n              lane, \n              priority, \n              description, \n              subtasks: tempModalSubtasks \n            };\n          }\n          return c;\n        });\n        showToast(\"Task updated\");\n      } else {\n        const newCard = {\n          id: `card-${Date.now()}`,\n          title,\n          lane,\n          priority,\n          description,\n          subtasks: tempModalSubtasks,\n          expanded: true\n        };\n        updatedCards.push(newCard);\n        showToast(\"Task created\");\n      }\n\n      saveSyncedState({ ...state, cards: updatedCards });\n      closeTaskModal();\n    }\n\n    renderBoard();\n  </script>\n</body>\n</html>",
