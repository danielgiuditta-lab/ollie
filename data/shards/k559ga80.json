  "ownerId": "100789219461204006343",
  "files": [
    {
      "id": "1E5v7RXpHXKo60xB66hCYtJfi-gSBRMUm",
      "name": "index.html",
      "type": "code",
      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>FIFA World Cup Live Bracket</title>\n  <!-- Tailwind CSS -->\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <!-- Google Fonts -->\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap\" rel=\"stylesheet\">\n  <!-- Lucide Icons -->\n  <script src=\"https://unpkg.com/lucide@latest\"></script>\n  <style>\n    body {\n      font-family: 'Plus Jakarta Sans', sans-serif;\n      background: radial-gradient(circle at 50% 0%, #0f172a 0%, #020617 100%);\n    }\n    /* Custom scrollbar for seamless navigation */\n    ::-webkit-scrollbar {\n      width: 6px;\n      height: 6px;\n    }\n    ::-webkit-scrollbar-track {\n      background: rgba(15, 23, 42, 0.3);\n    }\n    ::-webkit-scrollbar-thumb {\n      background: rgba(59, 130, 246, 0.5);\n      border-radius: 99px;\n    }\n    ::-webkit-scrollbar-thumb:hover {\n      background: rgba(59, 130, 246, 0.8);\n    }\n    /* Confetti animation */\n    @keyframes confetti {\n      0% { transform: translateY(-10px) rotate(0deg); opacity: 1; }\n      100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }\n    }\n    .confetti-piece {\n      position: absolute;\n      width: 10px;\n      height: 10px;\n      border-radius: 2px;\n      animation: confetti 4s linear infinite;\n    }\n  </style>\n</head>\n<body class=\"text-slate-100 min-h-screen flex flex-col relative overflow-x-hidden pb-12\">\n\n  <!-- Confetti Container -->\n  <div id=\"confetti-container\" class=\"absolute inset-0 pointer-events-none z-50 overflow-hidden\"></div>\n\n  <!-- Header -->\n  <header class=\"border-b border-slate-800/80 bg-slate-950/40 backdrop-blur-md sticky top-0 z-40 px-6 py-4\">\n    <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4\">\n      <div class=\"flex items-center gap-3\">\n        <div class=\"p-2.5 bg-gradient-to-tr from-yellow-500 to-amber-400 rounded-xl shadow-lg shadow-yellow-500/10\">\n          <i data-lucide=\"trophy\" class=\"w-6 h-6 text-slate-950\"></i>\n        </div>\n        <div>\n          <h1 class=\"text-xl font-extrabold tracking-tight bg-gradient-to-r from-white via-slate-200 to-slate-400 bg-clip-text text-transparent\">\n            World Cup Bracket\n          </h1>\n          <p class=\"text-xs text-slate-400 flex items-center gap-1.5 mt-0.5\">\n            <span id=\"sync-status\" class=\"inline-block w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse\"></span>\n            <span id=\"sync-text\">Live Synchronized</span>\n          </p>\n        </div>\n      </div>\n\n      <!-- Controls -->\n      <div class=\"flex flex-wrap items-center gap-3\">\n        <button onclick=\"quickFillFavorites()\" class=\"flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-xl bg-slate-900 border border-slate-800 hover:border-slate-700 hover:bg-slate-800 active:scale-95 transition-all text-slate-300\">\n          <i data-lucide=\"sparkles\" class=\"w-4 h-4 text-amber-400\"></i>\n          Predict Favorites\n        </button>\n        <button onclick=\"simulateBracket()\" class=\"flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-xl bg-blue-600/10 border border-blue-500/20 text-blue-400 hover:bg-blue-600/20 active:scale-95 transition-all\">\n          <i data-lucide=\"play\" class=\"w-4 h-4\"></i>\n          Simulate Rest\n        </button>\n        <button onclick=\"resetBracket()\" class=\"flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-xl bg-red-500/10 border border-red-500/20 text-red-400 hover:bg-red-500/20 active:scale-95 transition-all\">\n          <i data-lucide=\"refresh-cw\" class=\"w-4 h-4\"></i>\n          Reset\n        </button>\n      </div>\n    </div>\n  </header>\n\n  <!-- Responsive Switcher (Mobile Only) -->\n  <div class=\"xl:hidden flex justify-center gap-2 px-4 py-3 mt-4 bg-slate-900/40 border-y border-slate-800/60 sticky top-[73px] z-30 backdrop-blur-md\">\n    <button onclick=\"switchMobileRound('r16')\" id=\"tab-r16\" class=\"px-3 py-1.5 rounded-lg text-xs font-semibold bg-blue-600 text-white transition-all\">Round of 16</button>\n    <button onclick=\"switchMobileRound('qf')\" id=\"tab-qf\" class=\"px-3 py-1.5 rounded-lg text-xs font-semibold bg-slate-800 text-slate-400 hover:bg-slate-700 transition-all\">Quarterfinals</button>\n    <button onclick=\"switchMobileRound('sf')\" id=\"tab-sf\" class=\"px-3 py-1.5 rounded-lg text-xs font-semibold bg-slate-800 text-slate-400 hover:bg-slate-700 transition-all\">Semifinals</button>\n    <button onclick=\"switchMobileRound('final')\" id=\"tab-final\" class=\"px-3 py-1.5 rounded-lg text-xs font-semibold bg-slate-800 text-slate-400 hover:bg-slate-700 transition-all\">Finals</button>\n  </div>\n\n  <main class=\"flex-grow max-w-[1600px] w-full mx-auto p-4 md:p-8 flex flex-col justify-center\">\n    \n    <!-- Desktop Layout (Full Bracket Grid) -->\n    <div class=\"grid grid-cols-1 xl:grid-cols-4 gap-8 xl:gap-6 items-stretch justify-center h-full xl:min-h-[850px] relative\">\n      \n      <!-- COLUMN 1: ROUND OF 16 -->\n      <div id=\"col-r16\" class=\"flex flex-col justify-between gap-4 h-full xl:min-w-[310px] mobile-round-col\">\n        <h3 class=\"hidden xl:flex items-center gap-2 font-bold text-sm tracking-widest uppercase text-slate-400 mb-2 px-2\">\n          <i data-lucide=\"shield-alert\" class=\"w-4 h-4 text-blue-400\"></i>\n          Round of 16\n        </h3>\n        <div class=\"flex flex-col gap-4 justify-between h-full\" id=\"r16-container\"></div>\n      </div>\n\n      <!-- COLUMN 2: QUARTERFINALS -->\n      <div id=\"col-qf\" class=\"hidden xl:flex flex-col justify-around gap-4 h-full xl:min-w-[310px] mobile-round-col\">\n        <h3 class=\"hidden xl:flex items-center gap-2 font-bold text-sm tracking-widest uppercase text-slate-400 mb-2 px-2\">\n          <i data-lucide=\"shield\" class=\"w-4 h-4 text-emerald-400\"></i>\n          Quarterfinals\n        </h3>\n        <div class=\"flex flex-col gap-12 justify-around h-full\" id=\"qf-container\"></div>\n      </div>\n\n      <!-- COLUMN 3: SEMIFINALS -->\n      <div id=\"col-sf\" class=\"hidden xl:flex flex-col justify-around gap-4 h-full xl:min-w-[310px] mobile-round-col\">\n        <h3 class=\"hidden xl:flex items-center gap-2 font-bold text-sm tracking-widest uppercase text-slate-400 mb-2 px-2\">\n          <i data-lucide=\"swords\" class=\"w-4 h-4 text-purple-400\"></i>\n          Semifinals\n        </h3>\n        <div class=\"flex flex-col gap-24 justify-around h-full\" id=\"sf-container\"></div>\n      </div>\n\n      <!-- COLUMN 4: FINALS & CHAMPION -->\n      <div id=\"col-final\" class=\"hidden xl:flex flex-col justify-center gap-8 h-full xl:min-w-[310px] mobile-round-col\">\n        <!-- Final Match Container -->\n        <div class=\"flex flex-col gap-4\">\n          <h3 class=\"hidden xl:flex items-center gap-2 font-bold text-sm tracking-widest uppercase text-slate-400 mb-2 px-2\">\n            <i data-lucide=\"star\" class=\"w-4 h-4 text-amber-400\"></i>\n            Grand Final\n          </h3>\n          <div id=\"final-container\"></div>\n        </div>\n\n        <!-- Champion Showcase Card -->\n        <div class=\"bg-gradient-to-tr from-slate-900 to-slate-950 border-2 border-amber-500/40 rounded-3xl p-6 shadow-2xl shadow-amber-500/5 text-center flex flex-col items-center justify-center relative overflow-hidden group\">\n          <div class=\"absolute -top-12 -left-12 w-24 h-24 bg-amber-500/10 rounded-full blur-2xl group-hover:bg-amber-500/20 transition-all\"></div>\n          <div class=\"absolute -bottom-12 -right-12 w-24 h-24 bg-yellow-500/10 rounded-full blur-2xl group-hover:bg-yellow-500/20 transition-all\"></div>\n          \n          <div class=\"p-4 bg-amber-500/10 rounded-full mb-4 relative z-10 animate-bounce\">\n            <i data-lucide=\"crown\" class=\"w-8 h-8 text-amber-400\"></i>\n          </div>\n          <span class=\"text-xs font-bold tracking-widest text-amber-400 uppercase\">World Cup Champion</span>\n          <div id=\"champion-showcase\" class=\"mt-3 flex flex-col items-center justify-center\">\n            <!-- Dynamic Content -->\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </main>\n\n  <script>\n    const envId = window.__sandboxEnvId;\n    const syncKey = \"world_cup_bracket_v1\";\n\n    // Power index for auto predicting favorites\n    const TEAM_POWERS = {\n      ar: 95, br: 94, fr: 93, pt: 90, es: 89, nl: 88, gb: 88, hr: 86,\n      ma: 84, ch: 82, jp: 80, us: 78, sn: 76, kr: 75, pl: 74, au: 72\n    };\n\n    const initialMatches = {\n      // Round of 16\n      'r16-1': { round: 'r16', nextMatchId: 'qf-1', nextTeamSlot: 'team1', team1: { name: 'Netherlands', code: 'nl', score: '' }, team2: { name: 'USA', code: 'us', score: '' }, winner: null },\n      'r16-2': { round: 'r16', nextMatchId: 'qf-1', nextTeamSlot: 'team2', team1: { name: 'Argentina', code: 'ar', score: '' }, team2: { name: 'Australia', code: 'au', score: '' }, winner: null },\n      'r16-3': { round: 'r16', nextMatchId: 'qf-2', nextTeamSlot: 'team1', team1: { name: 'Japan', code: 'jp', score: '' }, team2: { name: 'Croatia', code: 'hr', score: '' }, winner: null },\n      'r16-4': { round: 'r16', nextMatchId: 'qf-2', nextTeamSlot: 'team2', team1: { name: 'Brazil', code: 'br', score: '' }, team2: { name: 'South Korea', code: 'kr', score: '' }, winner: null },\n      'r16-5': { round: 'r16', nextMatchId: 'qf-3', nextTeamSlot: 'team1', team1: { name: 'England', code: 'gb', score: '' }, team2: { name: 'Senegal', code: 'sn', score: '' }, winner: null },\n      'r16-6': { round: 'r16', nextMatchId: 'qf-3', nextTeamSlot: 'team2', team1: { name: 'France', code: 'fr', score: '' }, team2: { name: 'Poland', code: 'pl', score: '' }, winner: null },\n      'r16-7': { round: 'r16', nextMatchId: 'qf-4', nextTeamSlot: 'team1', team1: { name: 'Morocco', code: 'ma', score: '' }, team2: { name: 'Spain', code: 'es', score: '' }, winner: null },\n      'r16-8': { round: 'r16', nextMatchId: 'qf-4', nextTeamSlot: 'team2', team1: { name: 'Portugal', code: 'pt', score: '' }, team2: { name: 'Switzerland', code: 'ch', score: '' }, winner: null },\n\n      // Quarterfinals\n      'qf-1': { round: 'qf', nextMatchId: 'sf-1', nextTeamSlot: 'team1', team1: { name: 'TBD', code: '', score: '' }, team2: { name: 'TBD', code: '', score: '' }, winner: null },\n      'qf-2': { round: 'qf', nextMatchId: 'sf-1', nextTeamSlot: 'team2', team1: { name: 'TBD', code: '', score: '' }, team2: { name: 'TBD', code: '', score: '' }, winner: null },\n      'qf-3': { round: 'qf', nextMatchId: 'sf-2', nextTeamSlot: 'team1', team1: { name: 'TBD', code: '', score: '' }, team2: { name: 'TBD', code: '', score: '' }, winner: null },\n      'qf-4': { round: 'qf', nextMatchId: 'sf-2', nextTeamSlot: 'team2', team1: { name: 'TBD', code: '', score: '' }, team2: { name: 'TBD', code: '', score: '' }, winner: null },\n\n      // Semifinals\n      'sf-1': { round: 'sf', nextMatchId: 'final', nextTeamSlot: 'team1', team1: { name: 'TBD', code: '', score: '' }, team2: { name: 'TBD', code: '', score: '' }, winner: null },\n      'sf-2': { round: 'sf', nextMatchId: 'final', nextTeamSlot: 'team2', team1: { name: 'TBD', code: '', score: '' }, team2: { name: 'TBD', code: '', score: '' }, winner: null },\n\n      // Final\n      'final': { round: 'final', nextMatchId: 'champion', nextTeamSlot: 'champion', team1: { name: 'TBD', code: '', score: '' }, team2: { name: 'TBD', code: '', score: '' }, winner: null },\n      \n      // Champion\n      'champion': { name: 'TBD', code: '' }\n    };\n\n    let state = {\n      matches: JSON.parse(JSON.stringify(initialMatches))\n    };\n\n    let lastStateStr = \"\";\n    let mobileRound = 'r16';\n\n    // Sound Synthesizer via Web Audio API\n    const synth = {\n      ctx: null,\n      init() {\n        if (!this.ctx) {\n          this.ctx = new (window.AudioContext || window.webkitAudioContext)();\n        }\n      },\n      playClick() {\n        this.init();\n        if (!this.ctx) return;\n        const osc = this.ctx.createOscillator();\n        const gain = this.ctx.createGain();\n        osc.connect(gain);\n        gain.connect(this.ctx.destination);\n        osc.type = 'sine';\n        osc.frequency.setValueAtTime(500, this.ctx.currentTime);\n        osc.frequency.exponentialRampToValueAtTime(150, this.ctx.currentTime + 0.1);\n        gain.gain.setValueAtTime(0.05, this.ctx.currentTime);\n        gain.gain.linearRampToValueAtTime(0, this.ctx.currentTime + 0.1);\n        osc.start();\n        osc.stop(this.ctx.currentTime + 0.1);\n      },\n      playSuccess() {\n        this.init();\n        if (!this.ctx) return;\n        const notes = [440, 554.37, 659.25, 880];\n        const now = this.ctx.currentTime;\n        notes.forEach((freq, idx) => {\n          const osc = this.ctx.createOscillator();\n          const gain = this.ctx.createGain();\n          osc.connect(gain);\n          gain.connect(this.ctx.destination);\n          osc.type = 'triangle';\n          osc.frequency.setValueAtTime(freq, now + idx * 0.08);\n          gain.gain.setValueAtTime(0.06, now + idx * 0.08);\n          gain.gain.linearRampToValueAtTime(0, now + idx * 0.08 + 0.25);\n          osc.start(now + idx * 0.08);\n          osc.stop(now + idx * 0.08 + 0.25);\n        });\n      },\n      playChampion() {\n        this.init();\n        if (!this.ctx) return;\n        const now = this.ctx.currentTime;\n        const chords = [\n          [261.63, 329.63, 392.00, 523.25], // C major\n          [349.23, 440.00, 523.25, 698.46], // F major\n          [392.00, 493.88, 587.33, 783.99], // G major\n          [523.25, 659.25, 783.99, 1046.50] // C high major\n        ];\n        chords.forEach((chord, step) => {\n          chord.forEach((freq) => {\n            const osc = this.ctx.createOscillator();\n            const gain = this.ctx.createGain();\n            osc.connect(gain);\n            gain.connect(this.ctx.destination);\n            osc.type = 'sawtooth';\n            osc.frequency.setValueAtTime(freq, now + step * 0.22);\n            gain.gain.setValueAtTime(0.03, now + step * 0.22);\n            gain.gain.linearRampToValueAtTime(0, now + step * 0.22 + 0.5);\n            osc.start(now + step * 0.22);\n            osc.stop(now + step * 0.22 + 0.5);\n          });\n        });\n      }\n    };\n\n    // Confetti Effect\n    function triggerConfetti() {\n      const colors = ['#f59e0b', '#10b981', '#3b82f6', '#ec4899', '#8b5cf6'];\n      const container = document.getElementById('confetti-container');\n      container.innerHTML = '';\n      for (let i = 0; i < 70; i++) {\n        const p = document.createElement('div');\n        p.className = 'confetti-piece';\n        p.style.left = Math.random() * 100 + 'vw';\n        p.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];\n        p.style.animationDelay = Math.random() * 2 + 's';\n        p.style.animationDuration = (Math.random() * 2 + 2) + 's';\n        container.appendChild(p);\n      }\n      setTimeout(() => container.innerHTML = '', 5000);\n    }\n\n    // Flag URL Generator with reliable fallback\n    function getFlagHtml(code, teamName) {\n      if (!code || code === 'TBD' || teamName === 'TBD') {\n        return `<div class=\"w-9 h-6 rounded bg-slate-800 border border-slate-700/60 flex items-center justify-center text-slate-500\">\n          <i data-lucide=\"help-circle\" class=\"w-3.5 h-3.5\"></i>\n        </div>`;\n      }\n      // Special handle for England gb-eng on flagcdn\n      const flagCode = code === 'gb' ? 'gb-eng' : code.toLowerCase();\n      return `<img src=\"https://flagcdn.com/w40/${flagCode}.png\" alt=\"${teamName}\" class=\"w-9 h-6 object-cover rounded shadow border border-slate-800 transition-transform duration-200 group-hover:scale-105\" onerror=\"this.src='https://flagcdn.com/w40/un.png'\">`;\n    }\n\n    // Render Function\n    function renderBracket() {\n      const r16Cont = document.getElementById('r16-container');\n      const qfCont = document.getElementById('qf-container');\n      const sfCont = document.getElementById('sf-container');\n      const finalCont = document.getElementById('final-container');\n      const champShowcase = document.getElementById('champion-showcase');\n\n      r16Cont.innerHTML = '';\n      qfCont.innerHTML = '';\n      sfCont.innerHTML = '';\n      finalCont.innerHTML = '';\n\n      Object.entries(state.matches).forEach(([matchId, match]) => {\n        if (matchId === 'champion') return;\n\n        const isWinner1 = match.winner === 'team1';\n        const isWinner2 = match.winner === 'team2';\n        const hasStarted = match.team1.code && match.team2.code;\n\n        const matchHtml = `\n          <div class=\"bg-slate-900/50 backdrop-blur-md border border-slate-800 rounded-2xl p-3 shadow-lg hover:border-blue-500/40 hover:shadow-blue-500/5 transition-all duration-300 relative group flex flex-col justify-center\">\n            \n            <!-- Match Header Info -->\n            <div class=\"flex items-center justify-between text-[10px] text-slate-500 font-bold uppercase tracking-wider mb-2 border-b border-slate-800/40 pb-1.5\">\n              <span>Match ${matchId.toUpperCase()}</span>\n              ${match.winner ? '<span class=\"text-emerald-500 flex items-center gap-0.5\"><i data-lucide=\"check-circle\" class=\"w-3 h-3\"></i> Decided</span>' : '<span class=\"text-slate-600\">Prediction Pending</span>'}\n            </div>\n\n            <div class=\"space-y-2\">\n              <!-- TEAM 1 -->\n              <div onclick=\"selectWinner('${matchId}', 'team1')\" class=\"flex items-center justify-between p-1.5 rounded-xl cursor-pointer transition-all ${isWinner1 ? 'bg-emerald-500/10 border border-emerald-500/30' : 'hover:bg-slate-800/50 border border-transparent'} ${isWinner2 ? 'opacity-40' : ''}\">\n                <div class=\"flex items-center gap-2.5 min-w-0\">\n                  ${getFlagHtml(match.team1.code, match.team1.name)}\n                  <span class=\"text-xs font-semibold truncate ${isWinner1 ? 'text-emerald-400 font-bold' : 'text-slate-200'}\">\n                    ${match.team1.name}\n                  </span>\n                </div>\n                <div class=\"flex items-center gap-2\">\n                  <input type=\"text\" \n                    id=\"${matchId}-score1\" \n                    value=\"${match.team1.score !== undefined ? match.team1.score : ''}\" \n                    oninput=\"updateScore('${matchId}', 'team1', this.value)\" \n                    onclick=\"event.stopPropagation()\"\n                    placeholder=\"-\" \n                    class=\"w-8 h-7 bg-slate-950/80 border border-slate-800 text-center font-bold text-xs rounded-lg text-white focus:border-blue-500 outline-none\"\n                    ${!hasStarted ? 'disabled' : ''}\n                  />\n                  ${isWinner1 ? '<i data-lucide=\"crown\" class=\"w-4 h-4 text-amber-400 animate-pulse shrink-0\"></i>' : '<div class=\"w-4 h-4 shrink-0\"></div>'}\n                </div>\n              </div>\n\n              <!-- TEAM 2 -->\n              <div onclick=\"selectWinner('${matchId}', 'team2')\" class=\"flex items-center justify-between p-1.5 rounded-xl cursor-pointer transition-all ${isWinner2 ? 'bg-emerald-500/10 border border-emerald-500/30' : 'hover:bg-slate-800/50 border border-transparent'} ${isWinner1 ? 'opacity-40' : ''}\">\n                <div class=\"flex items-center gap-2.5 min-w-0\">\n                  ${getFlagHtml(match.team2.code, match.team2.name)}\n                  <span class=\"text-xs font-semibold truncate ${isWinner2 ? 'text-emerald-400 font-bold' : 'text-slate-200'}\">\n                    ${match.team2.name}\n                  </span>\n                </div>\n                <div class=\"flex items-center gap-2\">\n                  <input type=\"text\" \n                    id=\"${matchId}-score2\" \n                    value=\"${match.team2.score !== undefined ? match.team2.score : ''}\" \n                    oninput=\"updateScore('${matchId}', 'team2', this.value)\" \n                    onclick=\"event.stopPropagation()\"\n                    placeholder=\"-\" \n                    class=\"w-8 h-7 bg-slate-950/80 border border-slate-800 text-center font-bold text-xs rounded-lg text-white focus:border-blue-500 outline-none\"\n                    ${!hasStarted ? 'disabled' : ''}\n                  />\n                  ${isWinner2 ? '<i data-lucide=\"crown\" class=\"w-4 h-4 text-amber-400 animate-pulse shrink-0\"></i>' : '<div class=\"w-4 h-4 shrink-0\"></div>'}\n                </div>\n              </div>\n            </div>\n          </div>\n        `;\n\n        if (match.round === 'r16') r16Cont.insertAdjacentHTML('beforeend', matchHtml);\n        else if (match.round === 'qf') qfCont.insertAdjacentHTML('beforeend', matchHtml);\n        else if (match.round === 'sf') sfCont.insertAdjacentHTML('beforeend', matchHtml);\n        else if (match.round === 'final') finalCont.insertAdjacentHTML('beforeend', matchHtml);\n      });\n\n      // Render Champion Showcase\n      const champ = state.matches.champion;\n      if (champ && champ.name !== 'TBD') {\n        champShowcase.innerHTML = `\n          <div class=\"mt-2 group\">\n            <div class=\"flex justify-center mb-3\">\n              <img src=\"https://flagcdn.com/w160/${champ.code.toLowerCase()}.png\" alt=\"${champ.name}\" class=\"w-24 h-16 object-cover rounded-xl shadow-2xl border border-amber-500/30 transition-transform duration-500 group-hover:scale-110\">\n            </div>\n            <h4 class=\"text-xl font-extrabold text-white tracking-tight drop-shadow-md\">${champ.name}</h4>\n            <div class=\"inline-flex items-center gap-1.5 px-3 py-1 bg-amber-500/10 text-amber-300 text-[10px] uppercase tracking-widest font-extrabold rounded-full border border-amber-500/20 mt-3 animate-pulse\">\n              🏆 Champion crowned\n            </div>\n          </div>\n        `;\n      } else {\n        champShowcase.innerHTML = `\n          <div class=\"flex flex-col items-center justify-center py-4 text-slate-600\">\n            <div class=\"w-16 h-10 rounded bg-slate-900 border border-slate-800 flex items-center justify-center mb-2\">\n              <i data-lucide=\"trophy\" class=\"w-5 h-5\"></i>\n            </div>\n            <span class=\"text-xs font-semibold\">TBD</span>\n          </div>\n        `;\n      }\n\n      lucide.createIcons();\n      applyMobileVisibility();\n    }\n\n    // Select winner action and cascade down the bracket\n    function selectWinner(matchId, winnerTeamSlot) {\n      synth.playClick();\n      const match = state.matches[matchId];\n      if (!match || !match.team1.code || !match.team2.code) return;\n\n      propagateWinner(matchId, winnerTeamSlot);\n      saveState();\n      renderBracket();\n\n      // If champion is selected, trigger reward sound and confetti!\n      if (match.nextMatchId === 'champion') {\n        synth.playChampion();\n        triggerConfetti();\n      } else {\n        synth.playSuccess();\n      }\n    }\n\n    // Propagation logic for bracket predictions\n    function propagateWinner(matchId, winnerTeamSlot) {\n      const match = state.matches[matchId];\n      if (!match) return;\n\n      const winnerTeam = winnerTeamSlot ? match[winnerTeamSlot] : null;\n      match.winner = winnerTeamSlot;\n\n      if (match.nextMatchId === 'champion') {\n        state.matches.champion = winnerTeam ? { name: winnerTeam.name, code: winnerTeam.code } : { name: 'TBD', code: '' };\n      } else if (match.nextMatchId) {\n        const nextMatch = state.matches[match.nextMatchId];\n        if (nextMatch) {\n          const slot = match.nextTeamSlot; // 'team1' or 'team2'\n          const currentInSlot = nextMatch[slot];\n\n          if (!winnerTeam || currentInSlot.code !== winnerTeam.code) {\n            nextMatch[slot] = winnerTeam ? { name: winnerTeam.name, code: winnerTeam.code, score: '' } : { name: 'TBD', code: '', score: '' };\n            \n            // Invalidate the next match winner recursively\n            if (nextMatch.winner) {\n              nextMatch.winner = null;\n              propagateWinner(match.nextMatchId, null);\n            } else {\n              propagateWinner(match.nextMatchId, null);\n            }\n          }\n        }\n      }\n    }\n\n    // Update individual scores and auto-resolve logical winners if possible\n    function updateScore(matchId, teamSlot, value) {\n      const match = state.matches[matchId];\n      if (!match) return;\n\n      match[teamSlot].score = value;\n\n      // Auto resolve winner if scores are valid and different\n      const s1 = parseInt(match.team1.score);\n      const s2 = parseInt(match.team2.score);\n\n      if (!isNaN(s1) && !isNaN(s2)) {\n        if (s1 > s2) {\n          propagateWinner(matchId, 'team1');\n        } else if (s2 > s1) {\n          propagateWinner(matchId, 'team2');\n        }\n      }\n\n      saveState();\n      renderBracket();\n    }\n\n    // Simulate rest of matches randomly\n    async function simulateBracket() {\n      synth.playClick();\n      const roundOrder = ['r16', 'qf', 'sf', 'final'];\n      \n      for (const round of roundOrder) {\n        const roundMatches = Object.entries(state.matches).filter(([id, m]) => m.round === round);\n        for (const [id, match] of roundMatches) {\n          if (match.team1.code && match.team2.code) {\n            if (!match.winner) {\n              const score1 = Math.floor(Math.random() * 4);\n              const score2 = Math.floor(Math.random() * 4);\n              match.team1.score = score1;\n              match.team2.score = score2;\n              \n              let winnerSlot = 'team1';\n              if (score2 > score1) {\n                winnerSlot = 'team2';\n              } else if (score1 === score2) {\n                winnerSlot = Math.random() > 0.5 ? 'team1' : 'team2';\n              }\n              \n              propagateWinner(id, winnerSlot);\n              saveState();\n              renderBracket();\n              await new Promise(r => setTimeout(r, 120));\n            }\n          }\n        }\n      }\n      synth.playChampion();\n      triggerConfetti();\n    }\n\n    // Predict based on Power Indices (Logical Favorites)\n    async function quickFillFavorites() {\n      synth.playClick();\n      resetBracketData();\n      \n      const roundOrder = ['r16', 'qf', 'sf', 'final'];\n      \n      for (const round of roundOrder) {\n        const roundMatches = Object.entries(state.matches).filter(([id, m]) => m.round === round);\n        for (const [id, match] of roundMatches) {\n          if (match.team1.code && match.team2.code) {\n            const p1 = TEAM_POWERS[match.team1.code.toLowerCase()] || 50;\n            const p2 = TEAM_POWERS[match.team2.code.toLowerCase()] || 50;\n            \n            let s1 = Math.floor(Math.random() * 2) + (p1 > p2 ? 1 : 0);\n            let s2 = Math.floor(Math.random() * 2) + (p2 > p1 ? 1 : 0);\n            \n            if (s1 === s2) {\n              if (p1 > p2) s1++; else s2++;\n            }\n\n            match.team1.score = s1;\n            match.team2.score = s2;\n            \n            const winnerSlot = s1 > s2 ? 'team1' : 'team2';\n            propagateWinner(id, winnerSlot);\n            saveState();\n            renderBracket();\n            await new Promise(r => setTimeout(r, 100));\n          }\n        }\n      }\n      synth.playChampion();\n      triggerConfetti();\n    }\n\n    // Reset whole bracket state\n    function resetBracketData() {\n      state.matches = JSON.parse(JSON.stringify(initialMatches));\n    }\n\n    function resetBracket() {\n      synth.playClick();\n      resetBracketData();\n      saveState();\n      renderBracket();\n    }\n\n    // Mobile Navigation Switcher\n    function switchMobileRound(round) {\n      synth.playClick();\n      mobileRound = round;\n      \n      const tabs = ['r16', 'qf', 'sf', 'final'];\n      tabs.forEach(t => {\n        const btn = document.getElementById(`tab-${t}`);\n        if (t === round) {\n          btn.className = \"px-3 py-1.5 rounded-lg text-xs font-semibold bg-blue-600 text-white transition-all\";\n        } else {\n          btn.className = \"px-3 py-1.5 rounded-lg text-xs font-semibold bg-slate-800 text-slate-400 hover:bg-slate-700 transition-all\";\n        }\n      });\n\n      applyMobileVisibility();\n    }\n\n    function applyMobileVisibility() {\n      if (window.innerWidth >= 1280) return; // ignore on desktop\n      \n      const cols = ['r16', 'qf', 'sf', 'final'];\n      cols.forEach(c => {\n        const colEl = document.getElementById(`col-${c}`);\n        if (c === mobileRound) {\n          colEl.classList.remove('hidden');\n          colEl.classList.add('flex');\n        } else {\n          colEl.classList.remove('flex');\n          colEl.classList.add('hidden');\n        }\n      });\n    }\n\n    // Monitor screen resize to ensure proper view states\n    window.addEventListener('resize', () => {\n      if (window.innerWidth >= 1280) {\n        ['r16', 'qf', 'sf', 'final'].forEach(c => {\n          const colEl = document.getElementById(`col-${c}`);\n          colEl.classList.remove('hidden');\n          colEl.classList.add('flex');\n        });\n      } else {\n        switchMobileRound(mobileRound);\n      }\n    });\n\n    // Sync State Persistence Endpoints\n    async function loadSyncedState() {\n      if (!envId) return;\n      try {\n        const res = await fetch(`/api/sync/${envId}/${syncKey}`);\n        const json = await res.json();\n        if (json.data) {\n          const newStateStr = JSON.stringify(json.data);\n          if (newStateStr !== lastStateStr) {\n            const isTyping = document.activeElement && document.activeElement.tagName === 'INPUT';\n            if (!isTyping) {\n              state = json.data;\n              lastStateStr = newStateStr;\n              renderBracket();\n            } else {\n              const activeId = document.activeElement.id;\n              const activeVal = document.activeElement.value;\n              state = json.data;\n              lastStateStr = newStateStr;\n              renderBracket();\n              if (activeId) {\n                const el = document.getElementById(activeId);\n                if (el) {\n                  el.focus();\n                  el.value = activeVal;\n                }\n              }\n            }\n          }\n        }\n      } catch (err) {\n        console.error(\"Failed to load synced state:\", err);\n      }\n    }\n\n    async function saveState() {\n      lastStateStr = JSON.stringify(state);\n      if (!envId) return;\n      try {\n        await fetch(`/api/sync/${envId}/${syncKey}`, {\n          method: \"POST\",\n          headers: { \"Content-Type\": \"application/json\" },\n          body: JSON.stringify({ data: state })\n        });\n      } catch (err) {\n        console.error(\"Failed to save synced state:\", err);\n      }\n    }\n\n    // Initialize application\n    (function init() {\n      renderBracket();\n      if (envId) {\n        loadSyncedState();\n        setInterval(loadSyncedState, 2000);\n      } else {\n        const syncStatus = document.getElementById('sync-status');\n        const syncText = document.getElementById('sync-text');\n        if (syncStatus && syncText) {\n          syncStatus.className = \"inline-block w-2.5 h-2.5 rounded-full bg-amber-500 animate-pulse\";\n          syncText.textContent = \"Local Session (No Sync Active)\";\n        }\n      }\n    })();\n  </script>\n</body>\n</html>",
